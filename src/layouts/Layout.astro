---
export interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
}
const {
  title,
  description = "Short, honest ideas about ego, experience, and being fully alive.",
  canonicalURL = Astro.url.href,
  ogImage = "/og-default.png"
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Fonts: Fraunces (bold editorial) + DM Sans (readable body) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..800;1,9..144,400..800&family=DM+Sans:ital,opsz,wght@0,9..40,300..600;1,9..40,300..600&display=swap" rel="stylesheet" />

  <!-- Phosphor Icons -->
  <script src="https://unpkg.com/@phosphor-icons/web" defer></script>

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- JSON-LD -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Abby",
    "url": "https://chaoswithclarity.com",
    "sameAs": ["https://instagram.com/iamabbyjain","https://youtube.com/@iamabbyjain"]
  }
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* Foundations */
      --olive-deep:   #06050a;
      --olive-dark:   #0e0c14;
      --olive-mid:    #2a2418;

      /* Accent — antique gold */
      --olive-accent: #b8881e;
      --olive-bright: #d4a432;
      --olive-light:  #7a5c14;

      /* Backgrounds — warm parchment / cream */
      --bg:           #f5ece0;
      --bg-alt:       #ede5d8;
      --bg-card:      #faf7f2;

      /* Typography — dark ink on light */
      --text:         #0e0c14;
      --text-muted:   #6b5e4a;
      --text-faint:   #a89c8c;
      --text-on-dark: #f5ece0;
      --text-dim-dark:#c0a878;

      /* Structure */
      --gold:         #b8881e;
      --border:       #d8cdb8;
      --border-dark:  #c4b8a4;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    h1,h2,h3,h4,h5,h6 { font-family: 'Fraunces', Georgia, serif; line-height: 1.1; }
    img { max-width: 100%; height: auto; display: block; }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 0 3rem; height: 4.25rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; color: var(--text);
    }
    .nav-logo svg { flex-shrink: 0; }
    .nav-logo-text {
      font-family: 'Fraunces', serif;
      font-size: 0.92rem;
      font-weight: 300;
      font-variant: small-caps;
      letter-spacing: 0.16em;
      color: var(--text);
      line-height: 1;
    }
    .nav-links { display: flex; align-items: center; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.76rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--text-muted); text-decoration: none; font-weight: 500;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--text); }
    .nav-cta {
      background: var(--olive-accent) !important;
      color: var(--text-on-dark) !important;
      padding: 0.55rem 1.3rem; font-weight: 600 !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--olive-bright) !important; color: var(--text-on-dark) !important; }

    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px; background: none; border: none;
    }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--text); }

    @media (max-width: 768px) {
      nav { padding: 0 1.5rem; }
      .nav-links {
        display: none; position: absolute; top: 4.25rem; left: 0; right: 0;
        background: var(--bg); flex-direction: column;
        align-items: flex-start; padding: 1.5rem 2rem;
        border-top: 1px solid var(--border); gap: 1.25rem;
      }
      .nav-links.open { display: flex; }
      .hamburger { display: flex; }
    }

    /* POEM MODAL */
    #poem-modal {
      display: none; position: fixed; inset: 0; z-index: 1000;
      background: rgba(6,5,10,0.92); backdrop-filter: blur(8px);
      align-items: center; justify-content: center; padding: 2rem;
    }
    #poem-modal.open { display: flex; }
    #poem-modal-inner {
      background: var(--bg); max-width: 36rem; width: 100%;
      max-height: 85vh; overflow-y: auto; padding: 3rem;
      position: relative; border-left: 4px solid var(--olive-accent);
    }
    #poem-modal-close {
      position: absolute; top: 1.25rem; right: 1.25rem;
      cursor: pointer; background: none; border: none;
      font-size: 1.4rem; color: var(--text-muted); padding: 0.25rem;
    }
    #poem-modal-close:hover { color: var(--text); }

    /* FOOTER */
    footer {
      background: var(--olive-deep); color: var(--text-dim-dark);
      padding: 2.5rem 3rem; font-size: 0.82rem;
    }
    .footer-inner {
      max-width: 72rem; margin: 0 auto;
      display: flex; align-items: center;
      justify-content: space-between; flex-wrap: wrap; gap: 1.5rem;
    }
    .footer-links { display: flex; flex-wrap: wrap; gap: 1.75rem; }
    .footer-links a {
      color: var(--text-dim-dark); text-decoration: none;
      font-size: 0.78rem; letter-spacing: 0.06em; transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--text-on-dark); }

    @media (max-width: 600px) {
      footer { padding: 2rem 1.5rem; }
      .footer-inner { flex-direction: column; align-items: flex-start; gap: 1rem; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="30" height="30" aria-hidden="true">
        <path d="M37.0,20.0L36.9,21.5L36.6,23.0L36.2,24.4L35.7,25.8L35.0,27.2L34.3,28.5L33.4,29.7L32.4,30.8L31.4,31.8L30.2,32.7L29.0,33.5L27.7,34.2L26.4,34.7L25.1,35.2L23.7,35.5L22.3,35.7L20.8,35.8L19.4,35.7L18.0,35.5L16.7,35.2L15.4,34.8L14.1,34.3L12.9,33.6L11.7,32.9L10.7,32.0L9.7,31.1L8.8,30.1L8.0,29.0L7.3,27.8L6.7,26.6L6.2,25.4L5.9,24.1L5.6,22.8L5.5,21.5L5.5,20.2L5.6,19.0L5.8,17.7L6.2,16.5L6.6,15.3L7.2,14.1L7.8,13.0L8.5,12.0L9.3,11.1L10.2,10.2L11.2,9.4L12.2,8.8L13.3,8.2L14.4,7.7L15.5,7.3L16.7,7.0L17.9,6.9L19.1,6.8L20.3,6.8L21.4,7.0L22.6,7.2L23.7,7.6L24.7,8.0L25.7,8.6L26.7,9.2L27.6,9.9L28.4,10.7L29.1,11.5L29.8,12.4L30.4,13.3L30.9,14.3L31.3,15.4L31.6,16.4L31.8,17.5L31.9,18.5L31.9,19.6L31.8,20.7L31.6,21.7L31.3,22.7L31.0,23.7L30.5,24.6L30.0,25.5L29.4,26.3L28.7,27.1L28.0,27.8L27.3,28.4L26.4,28.9L25.6,29.4L24.7,29.8L23.7,30.1L22.8,30.3L21.9,30.5L20.9,30.5L20.0,30.5L19.1,30.3L18.1,30.1L17.3,29.9L16.4,29.5L15.6,29.1L14.9,28.6L14.2,28.0L13.5,27.4L13.0,26.8L12.5,26.0L12.0,25.3L11.6,24.5L11.4,23.7L11.1,22.9L11.0,22.1L10.9,21.3L10.9,20.5L11.0,19.7L11.1,18.9L11.4,18.1L11.6,17.4L12.0,16.7L12.4,16.0L12.8,15.4L13.4,14.8L13.9,14.3L14.5,13.8L15.1,13.4L15.8,13.1L16.4,12.8L17.1,12.6L17.8,12.5" stroke="#b8881e" stroke-width="0.8" fill="none" stroke-linecap="round" opacity="0.45" stroke-dasharray="2 2"/>
        <path d="M12.1,16.4L12.3,16.1L12.5,15.8L12.7,15.6L12.9,15.3L13.2,15.0L13.4,14.8L13.7,14.5L13.9,14.3L14.2,14.1L14.5,13.9L14.7,13.7L15.0,13.5L15.3,13.3L15.6,13.2L15.9,13.0L16.2,12.9L16.6,12.8L16.9,12.7L17.2,12.6L17.5,12.5L17.8,12.5L18.2,12.4L18.5,12.4L18.8,12.4L19.1,12.4L19.4,12.4L19.8,12.4L20.1,12.4L20.4,12.5L20.7,12.6L21.0,12.6L21.3,12.7L21.6,12.8L21.9,12.9L22.1,13.0L22.4,13.2L22.7,13.3L22.9,13.5L23.2,13.6L23.4,13.8L23.7,14.0L23.9,14.2L24.1,14.4L24.3,14.6L24.5,14.8L24.7,15.0L24.8,15.2L25.0,15.5L25.2,15.7L25.3,15.9L25.4,16.2L25.5,16.4L25.6,16.7L25.7,16.9L25.8,17.2L25.9,17.5L26.0,17.7L26.0,18.0L26.0,18.2L26.1,18.5L26.1,18.8L26.1,19.0L26.1,19.3L26.1,19.5L26.0,19.8L26.0,20.0L26.0,20.3L25.9,20.5L25.8,20.8L25.8,21.0L25.7,21.2L25.6,21.4L25.5,21.7L25.3,21.9L25.2,22.1L25.1,22.3L25.0,22.5L24.8,22.6L24.7,22.8L24.5,23.0L24.3,23.1L24.2,23.3L24.0,23.4L23.8,23.6L23.6,23.7L23.5,23.8L23.3,23.9L23.1,24.0L22.9,24.1L22.7,24.2L22.5,24.2L22.3,24.3L22.1,24.4L21.9,24.4L21.7,24.4L21.5,24.5L21.3,24.5L21.1,24.5L20.9,24.5L20.7,24.5L20.5,24.4L20.3,24.4L20.2,24.4L20.0,24.3L19.8,24.3L19.6,24.2L19.5,24.2L19.3,24.1L19.1,24.0L19.0,23.9L18.8,23.8L18.7,23.8L18.6,23.7L18.4,23.5L18.3,23.4L18.2,23.3L18.1,23.2L18.0,23.1L17.9,23.0L17.8,22.8L17.7,22.7L17.6,22.6L17.6,22.4L17.5,22.3L17.4,22.2L17.4,22.0L17.3,21.9L17.3,21.7L17.3,21.6L17.3,21.5L17.3,21.3L17.2,21.2L17.2,21.1L17.2,20.9L17.3,20.8L17.3,20.7L17.3,20.6L17.3,20.4L17.4,20.3L17.4,20.2L17.5,20.1L17.5,20.0L17.6,19.9L17.6,19.8L17.7,19.7L17.8,19.6L17.8,19.5L17.9,19.5L18.0,19.4L18.0,19.3L18.1,19.3L18.2,19.2L18.3,19.2L18.4,19.1L18.5,19.1L18.6,19.1L18.6,19.0L18.7,19.0L18.8,19.0L18.9,19.0L19.0,19.0L19.1,19.0L19.2,19.0L19.2,19.0L19.3,19.0L19.4,19.1L19.5,19.1L19.5,19.1L19.6,19.2L19.7,19.2L19.7,19.3L19.8,19.3L19.8,19.4L19.9,19.4L19.9,19.5L19.9,19.6L20.0,19.7L20.0,19.8L20.0,19.9L20.0,20.0" stroke="#b8881e" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="20" cy="20" r="1.9" fill="#b8881e"/>
        <circle cx="20" cy="20" r="0.85" fill="#d4a432"/>
      </svg>
      <span class="nav-logo-text">chaoswithclarity</span>
    </a>
    <ul class="nav-links" id="nav-menu">
      <li><a href="/writings">Writing</a></li>
      <li><a href="/offerings">Work with Abby</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/join" class="nav-cta">Get the Letters</a></li>
    </ul>
    <button class="hamburger" id="hamburger" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Poem Modal -->
  <div id="poem-modal" role="dialog" aria-modal="true" aria-labelledby="poem-modal-title">
    <div id="poem-modal-inner">
      <button id="poem-modal-close" aria-label="Close">✕</button>
      <p id="poem-modal-date" style="font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:0.75rem;font-weight:600;"></p>
      <h2 id="poem-modal-title" style="font-family:'Fraunces',serif;font-size:1.8rem;font-weight:700;color:var(--text);margin-bottom:1.75rem;"></h2>
      <div id="poem-modal-body" style="font-family:'Fraunces',serif;font-style:italic;color:var(--text-muted);font-size:1.05rem;line-height:2.2;border-left:3px solid var(--olive-accent);padding-left:1.5rem;margin-bottom:1.75rem;white-space:pre-line;"></div>
      <p id="poem-modal-reflection" style="font-size:0.87rem;color:var(--text-muted);line-height:1.9;border-top:1px solid var(--border);padding-top:1.25rem;display:none;"></p>
    </div>
  </div>

  <slot />

  <footer>
    <div class="footer-inner">
      <p>© 2026 Chaos With Clarity · Abby</p>
      <div class="footer-links">
        <a href="/writings">Writing</a>
        <a href="/offerings">Work with Abby</a>
        <a href="/about">About</a>
        <a href="/join">Letters</a>
        <a href="https://instagram.com/iamabbyjain" target="_blank" rel="noopener">Instagram</a>
        <a href="https://youtube.com/@iamabbyjain" target="_blank" rel="noopener">YouTube</a>
        <a href="mailto:abby@chaoswithclarity.com">abby@chaoswithclarity.com</a>
      </div>
    </div>
  </footer>

  <script>
    // Mobile nav
    document.getElementById('hamburger').addEventListener('click', () => {
      document.getElementById('nav-menu').classList.toggle('open');
    });

    // Poem modal
    document.querySelectorAll('[data-poem-card]').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => {
        const title = card.dataset.title || '';
        const date = card.dataset.date || '';
        const poem = card.dataset.poem || '';
        const reflection = card.dataset.reflection || '';
        document.getElementById('poem-modal-title').textContent = title;
        document.getElementById('poem-modal-date').textContent = date;
        document.getElementById('poem-modal-body').textContent = poem;
        const ref = document.getElementById('poem-modal-reflection');
        if (reflection) { ref.textContent = reflection; ref.style.display = 'block'; }
        else { ref.style.display = 'none'; }
        document.getElementById('poem-modal').classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });
    document.getElementById('poem-modal-close').addEventListener('click', closeModal);
    document.getElementById('poem-modal').addEventListener('click', e => {
      if (e.target === document.getElementById('poem-modal')) closeModal();
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
    function closeModal() {
      document.getElementById('poem-modal').classList.remove('open');
      document.body.style.overflow = '';
    }
  </script>

</body>
</html>
