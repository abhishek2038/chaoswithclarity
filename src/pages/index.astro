---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Chaos With Clarity | Abby"
  description="Short, honest ideas about ego, experience, and being fully alive — for people who think too much and feel even more."
>

  <!-- ══ HERO ══════════════════════════════════════════════ -->
  <section style="min-height:100svh;background:var(--olive-deep);display:flex;flex-direction:column;justify-content:center;padding:8rem 3rem 5rem;position:relative;overflow:hidden;">
    <!-- background texture lines -->
    <div style="position:absolute;inset:0;opacity:0.04;background:repeating-linear-gradient(0deg,transparent,transparent 80px,#fff 80px,#fff 81px);pointer-events:none;"></div>

    <div style="max-width:72rem;margin:0 auto;width:100%;position:relative;">
      <p style="font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--olive-light);margin-bottom:2rem;font-weight:600;">Chaos With Clarity</p>

      <h1 style="font-family:'Fraunces',serif;font-size:clamp(3.5rem,9vw,8rem);font-weight:800;color:var(--text-on-dark);letter-spacing:-0.03em;line-height:0.92;margin-bottom:2.5rem;">
        Short,<br/>
        <span style="color:var(--olive-light);font-style:italic;">honest</span><br/>
        ideas.
      </h1>

      <p style="color:var(--text-dim-dark);font-size:clamp(1rem,2vw,1.2rem);line-height:1.9;max-width:38rem;margin-bottom:3rem;font-weight:300;">
        On ego, experience, and being fully alive —<br/>
        for people who think too much and feel even more.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;">
        <a href="/writings" style="display:inline-block;background:var(--olive-accent);color:var(--text-on-dark);font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--olive-accent)'">Read the Writing</a>
        <a href="/join" style="display:inline-block;border:1px solid var(--olive-mid);color:var(--text-dim-dark);font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-light)';this.style.color='var(--text-on-dark)'" onmouseout="this.style.borderColor='var(--olive-mid)';this.style.color='var(--text-dim-dark)'">Get the Letters</a>
      </div>
    </div>
  </section>

  <!-- ══ THIS SPACE IS FOR YOU ══════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:6rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start;" class="for-you-grid">
      <div style="position:sticky;top:7rem;">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:1rem;font-weight:600;">This space is for you if</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;color:var(--text);line-height:1.05;">You feel it<br/><em style="font-weight:400;color:var(--text-muted);">before you<br/>name it.</em></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          ["You're doing well on paper, but something still feels off.", "You've built the life — but you're not sure it's yours."],
          ["You're exhausted by the performance of having it together.", "You'd rather feel real than feel impressive."],
          ["You want words that don't try to fix you.", "Just something honest in an inbox full of noise."],
          ["You're asking questions that no productivity hack can answer.", "What are we actually optimising for?"]
        ].map(([line1, line2], i) => (
          <div style={`padding:2rem 0;border-bottom:1px solid var(--border);${i===0?'border-top:1px solid var(--border);':''}`}>
            <p style="font-size:1rem;color:var(--text);font-weight:500;margin-bottom:0.4rem;">{line1}</p>
            <p style="font-size:0.95rem;color:var(--text-muted);">{line2}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ ESSAYS ════════════════════════════════════════════ -->
  <section style="background:var(--olive-deep);padding:6rem 3rem;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:3rem;flex-wrap:wrap;gap:1rem;">
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3rem);font-weight:700;color:var(--text-on-dark);">Essays</h2>
        <a href="/writings" style="font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--olive-light);text-decoration:none;font-weight:500;">All writing →</a>
      </div>

      <div style="display:grid;grid-template-columns:repeat(2,1fr);border:1px solid var(--border-dark);" class="essay-home-grid">
        {[
          {tag:"Attention & Technology", title:"Who Owns You?", blurb:"How our gadgets, purchases, and rewards slowly start controlling our thoughts, time, and emotions."},
          {tag:"AI & Human Experience", title:"We Were Never Meant for Intelligence", blurb:"Why AI is not the real threat — the danger is humans forgetting our edge was experience, not efficiency."},
          {tag:"Reality & Perception", title:"Choosing Reality Over Symbols", blurb:"How we mistake words and labels for the real thing, and what it means to actually live your own experience."},
          {tag:"Books & Mind", title:"When Reading Rewires You", blurb:"How books quietly change the way you see people and yourself long after you close the last page."},
        ].map((e,i) => (
          <article style={`padding:2.5rem;${i<2?'border-bottom:1px solid var(--border-dark);':''}${i%2===0?'border-right:1px solid var(--border-dark);':''}`}>
            <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--olive-light);margin-bottom:1rem;font-weight:600;">{e.tag}</p>
            <h3 style="font-family:'Fraunces',serif;font-size:1.4rem;font-weight:700;color:var(--text-on-dark);margin-bottom:0.75rem;line-height:1.2;">{e.title}</h3>
            <p style="color:var(--text-dim-dark);font-size:0.9rem;line-height:1.8;margin-bottom:1.25rem;">{e.blurb}</p>
            <span style="font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--olive-mid);font-weight:600;">Coming soon</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ FEATURED POEM ══════════════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:6rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);" class="poem-home-grid">

      <article style="padding:3.5rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:1.25rem;"
               data-poem-card
               data-title="Unstruck Silence (Anhat Nad)"
               data-date="March 2026"
               data-poem="There is a sound
that was never struck —
no string plucked, no drum hit,
no throat opened to release it.

It was here before you arrived.
It is here after the last thought
you'll ever think
dissolves.

You have heard it in the space
between two breaths —
not the inhale,
not the exhale,
but the pause that holds both,
the way a door frame holds
a house.

You have heard it in the room
after crying stops,
when the chest finally unclenches
and something older than grief
comes through.

The mystics called it Anahata —
unstruck.
The thing that hums
without cause,
loves without reason,
stays without being asked.

You think you have to earn stillness.
You think silence is the reward
for surviving.

But it is not earned.
It is only uncovered —
the way snow uncovers
ground
by melting."
               data-reflection="Anhat Nad is a concept from Indian classical music and tantra — the sound that was never struck. The Anahata chakra, or heart center, is said to resonate with this unstruck sound. I wrote this after a long meditation session where I kept waiting for something to happen. Nothing did. And then I realized — that was it.">
        <p style="font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--olive-accent);font-weight:600;">Featured Poem · March 2026</p>
        <h3 style="font-family:'Fraunces',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--text);line-height:1.15;">Unstruck Silence<br/><em style="font-weight:400;font-size:0.8em;color:var(--text-muted);">(Anhat Nad)</em></h3>
        <div style="font-family:'Fraunces',serif;font-style:italic;color:var(--text-muted);font-size:1.05rem;line-height:2.2;border-left:3px solid var(--olive-accent);padding-left:1.5rem;flex:1;">
          <p>There is a sound</p>
          <p>that was never struck —</p>
          <p>no string plucked, no drum hit,</p>
          <p>no throat opened to release it.</p>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <span style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--olive-accent);font-weight:600;">Click to read</span>
          <i class="ph ph-arrow-right" style="color:var(--olive-accent);font-size:0.9rem;"></i>
        </div>
      </article>

      <div style="background:var(--bg-alt);padding:3.5rem;display:flex;flex-direction:column;justify-content:space-between;gap:2rem;">
        <div>
          <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:1.5rem;font-weight:600;">About this space</p>
          <p style="font-family:'Fraunces',serif;font-size:1.4rem;font-weight:500;color:var(--text);line-height:1.5;margin-bottom:1.25rem;">
            "Spreadsheets couldn't answer the chest ache. So I write."
          </p>
          <p style="font-size:0.92rem;color:var(--text-muted);line-height:1.9;">Nine years of finance — from EY audit rooms to sitting across from founders who had everything and felt nothing — taught me one thing: clarity without depth is just noise with good formatting.</p>
        </div>
        <div>
          <a href="/about" style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:0.75rem 1.75rem;display:inline-block;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">About Abby →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ NEWSLETTER CTA ══════════════════════════════════════ -->
  <section style="background:var(--olive-dark);padding:6rem 3rem;">
    <div style="max-width:50rem;margin:0 auto;text-align:center;">
      <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-light);margin-bottom:1.5rem;font-weight:600;">The Letters</p>
      <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:var(--text-on-dark);line-height:1.05;margin-bottom:1.5rem;">
        Honest notes from<br/><em style="font-weight:400;color:var(--olive-light);">the middle of it all.</em>
      </h2>
      <p style="color:var(--text-dim-dark);font-size:0.95rem;line-height:1.9;max-width:36rem;margin:0 auto 2.5rem;font-weight:300;">
        Thoughts I don't share on Instagram or YouTube. Drafts, behind-the-scenes process, questions I'm still figuring out. No spam. No "daily grind" tips. Just honest notes.
      </p>
      <a href="/join" style="display:inline-block;background:var(--olive-accent);color:var(--text-on-dark);font-size:0.76rem;letter-spacing:0.18em;text-transform:uppercase;padding:1.1rem 2.5rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--olive-accent)'">Get the Letters</a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .for-you-grid { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
    .for-you-grid > div:first-child { position: static !important; }
    .essay-home-grid { grid-template-columns: 1fr !important; }
    .essay-home-grid article { border-right: none !important; border-bottom: 1px solid var(--border-dark) !important; }
    .poem-home-grid { grid-template-columns: 1fr !important; }
    .poem-home-grid > article { border-right: none !important; border-bottom: 1px solid var(--border) !important; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.5rem !important; padding-right: 1.5rem !important; }
  }
</style>
