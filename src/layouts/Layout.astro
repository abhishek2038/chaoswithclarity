---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Poetry, soul work, and founder clarity by Abby Jain." } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.js" defer></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { background: #f5ede2; color: #1a1612; font-family: 'Inter', sans-serif; font-weight: 300; line-height: 1.6; -webkit-font-smoothing: antialiased; }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1.4rem 3rem;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(245,237,226,0.93); backdrop-filter: blur(12px);
      border-bottom: 1px solid transparent; transition: border-color 0.3s;
    }
    nav.scrolled { border-bottom-color: #d9cfc0; }
    .nav-logo { font-family: 'Playfair Display', Georgia, serif; font-size: 1.1rem; font-weight: 700; color: #1a1612; text-decoration: none; }
    .nav-logo span { color: #b5763a; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: #7a6f63; text-decoration: none; font-weight: 400; transition: color 0.2s; }
    .nav-links a:hover { color: #1a1612; }

    #poem-modal { position: fixed; inset: 0; z-index: 200; background: #0f0d0b; display: flex; align-items: center; justify-content: center; padding: 2rem; opacity: 0; pointer-events: none; transition: opacity 0.35s; }
    #poem-modal.open { opacity: 1; pointer-events: all; }
    .poem-modal-inner { max-width: 42rem; width: 100%; max-height: 90vh; overflow-y: auto; }
    .poem-modal-close { position: absolute; top: 2rem; right: 2rem; background: none; border: none; color: #6b6055; cursor: pointer; font-size: 1.5rem; transition: color 0.2s; }
    .poem-modal-close:hover { color: #c9a478; }

    footer { background: #0f0d0b; color: #6b6055; padding: 3rem; text-align: center; margin-top: 6rem; }
    footer a { color: #6b6055; text-decoration: none; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s; }
    footer a:hover { color: #c9a478; }
    .footer-links { display: flex; gap: 2rem; justify-content: center; margin-top: 1rem; }

    @media (max-width: 768px) { nav { padding: 1.2rem 1.5rem; } .nav-links { gap: 1.5rem; } }
    @media (max-width: 560px) { .nav-links { display: none; } }
  </style>
</head>
<body>
  <nav id="site-nav">
    <a href="/" class="nav-logo">Chaos<span>·</span>Clarity</a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/writings">Writings</a></li>
      <li><a href="/offerings">Offerings</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/join">Join</a></li>
    </ul>
  </nav>

  <div id="poem-modal" role="dialog">
    <button class="poem-modal-close" id="close-poem-modal"><i class="ph ph-x"></i></button>
    <div class="poem-modal-inner">
      <p style="font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:#6b6055;margin-bottom:1.5rem;">← All Poems</p>
      <h2 id="modal-poem-title" style="font-family:'Playfair Display',serif;font-size:2rem;color:#f0e8dc;margin-bottom:0.5rem;font-weight:500;"></h2>
      <p id="modal-poem-date" style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:#6b6055;margin-bottom:2.5rem;"></p>
      <div id="modal-poem-body" style="font-family:'Playfair Display',serif;font-style:italic;color:#d4c4b0;font-size:1.1rem;line-height:2.1;white-space:pre-line;margin-bottom:3rem;"></div>
      <p id="modal-poem-reflection" style="font-size:0.88rem;color:#8a7d6e;line-height:1.9;border-top:1px solid #2a2520;padding-top:2rem;"></p>
    </div>
  </div>

  <slot />

  <footer>
    <p style="font-size:0.75rem;letter-spacing:0.08em;">© 2026 Chaos With Clarity</p>
    <div class="footer-links">
      <a href="https://instagram.com/iamabbyjain" target="_blank" rel="noopener">Instagram</a>
      <a href="https://youtube.com" target="_blank" rel="noopener">YouTube</a>
      <a href="https://instagram.com/iamabbyjain" target="_blank" rel="noopener">iamabbyjain (Finance)</a>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('site-nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));
    const modal = document.getElementById('poem-modal');
    const closeBtn = document.getElementById('close-poem-modal');
    document.querySelectorAll('[data-open-poem]').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-poem]');
        if (!card || !modal) return;
        document.getElementById('modal-poem-title').textContent = card.dataset.title || '';
        document.getElementById('modal-poem-date').textContent = card.dataset.date || '';
        document.getElementById('modal-poem-body').textContent = card.dataset.poem || '';
        document.getElementById('modal-poem-reflection').textContent = card.dataset.reflection || '';
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });
    closeBtn?.addEventListener('click', () => { modal?.classList.remove('open'); document.body.style.overflow = ''; });
    modal?.addEventListener('click', e => { if (e.target === modal) { modal.classList.remove('open'); document.body.style.overflow = ''; } });
  </script>
</body>
</html>
