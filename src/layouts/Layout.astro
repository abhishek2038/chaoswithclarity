---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: string;
}
const {
  title,
  description = "Poetry, soul work, and founder clarity by Abby Jain. A poet-CFO writing about money, mortality, and the strange gift of being alive.",
  image = "https://chaoswithclarity.com/og-image.jpg",
  type = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://chaoswithclarity.com");
const fullTitle = title.includes("Chaos With Clarity") ? title : `${title} | Chaos With Clarity`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="Chaos With Clarity" />
  <meta property="og:locale" content="en_IN" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />
  <meta name="twitter:creator" content="@iamabbyjain" />

  <!-- Additional SEO -->
  <meta name="author" content="Abby Jain" />
  <meta name="robots" content="index, follow" />
  <meta name="keywords" content="poetry, soul work, founder clarity, CFO, Abby Jain, chaos with clarity, meditative poetry, India, startup finance, spiritual writing" />
  <meta name="theme-color" content="#f3e8d8" />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Abby Jain",
    "url": "https://chaoswithclarity.com",
    "sameAs": [
      "https://instagram.com/iamabbyjain",
      "https://youtube.com/@iamabbyjain"
    ],
    "description": description,
    "jobTitle": "Poet · Fractional CFO · Soul Worker",
    "knowsAbout": ["Poetry", "Finance", "Soul Work", "Meditation", "Startup Finance"]
  })} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.js" defer></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      background: #f3e8d8;
      color: #1a1612;
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1.4rem 3rem;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(243,232,216,0.94); backdrop-filter: blur(14px);
      border-bottom: 1px solid transparent; transition: border-color 0.3s;
    }
    nav.scrolled { border-bottom-color: #cec5ad; }
    .nav-logo {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: #1a1612;
      text-decoration: none;
      letter-spacing: 0.02em;
    }
    .nav-logo span { color: #5d6b45; }
    .nav-links { display: flex; gap: 2.5rem; list-style: none; }
    .nav-links a {
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: #7a7260;
      text-decoration: none;
      font-weight: 400;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: #1a1612; }

    /* Poem modal */
    #poem-modal {
      position: fixed; inset: 0; z-index: 200;
      background: #0e0c09;
      display: flex; align-items: center; justify-content: center;
      padding: 2rem;
      opacity: 0; pointer-events: none; transition: opacity 0.35s;
    }
    #poem-modal.open { opacity: 1; pointer-events: all; }
    .poem-modal-inner {
      max-width: 42rem; width: 100%;
      max-height: 90vh; overflow-y: auto;
    }
    .poem-modal-close {
      position: absolute; top: 2rem; right: 2rem;
      background: none; border: none;
      color: #5a5048; cursor: pointer;
      font-size: 1.5rem; transition: color 0.2s;
    }
    .poem-modal-close:hover { color: #c17f3a; }

    /* Footer */
    footer {
      background: #0e0c09;
      color: #5a5048;
      padding: 3.5rem 3rem;
      text-align: center;
      margin-top: 6rem;
    }
    footer a {
      color: #5a5048;
      text-decoration: none;
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    footer a:hover { color: #c17f3a; }
    .footer-links { display: flex; gap: 2rem; justify-content: center; margin-top: 1rem; }
    .footer-divider {
      width: 3rem; height: 1px;
      background: #2a2520;
      margin: 1.5rem auto;
    }

    /* Global mobile helpers */
    @media (max-width: 768px) {
      nav { padding: 1.2rem 1.5rem; }
      .nav-links { gap: 1.5rem; }
      footer { padding: 2.5rem 1.5rem; }
    }
    @media (max-width: 560px) {
      .nav-links { display: none; }
      .footer-links { flex-direction: column; gap: 1rem; align-items: center; }
    }

    /* Sections with fixed padding — mobile override */
    @media (max-width: 640px) {
      [style*="padding:9rem 3rem"],
      [style*="padding:10rem 3rem"],
      [style*="padding:5rem 3rem"],
      [style*="padding:5.5rem 3rem"],
      [style*="padding:4rem 3rem"],
      [style*="padding:0 3rem"] {
        padding-left: 1.5rem !important;
        padding-right: 1.5rem !important;
      }
    }
  </style>
</head>
<body>
  <nav id="site-nav">
    <a href="/" class="nav-logo" aria-label="Chaos With Clarity — Home">Chaos<span>·</span>Clarity</a>
    <ul class="nav-links" role="navigation" aria-label="Main navigation">
      <li><a href="/">Home</a></li>
      <li><a href="/writings">Writings</a></li>
      <li><a href="/offerings">Offerings</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/join">Join</a></li>
    </ul>
  </nav>

  <div id="poem-modal" role="dialog" aria-modal="true" aria-label="Poem reader">
    <button class="poem-modal-close" id="close-poem-modal" aria-label="Close poem"><i class="ph ph-x"></i></button>
    <div class="poem-modal-inner">
      <p style="font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;color:#5a5048;margin-bottom:1.5rem;">← All Poems</p>
      <h2 id="modal-poem-title" style="font-family:'Cormorant Garamond',Georgia,serif;font-size:2.2rem;color:#f0e4d0;margin-bottom:0.5rem;font-weight:500;letter-spacing:0.01em;"></h2>
      <p id="modal-poem-date" style="font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:#5a5048;margin-bottom:2.5rem;"></p>
      <div id="modal-poem-body" style="font-family:'Cormorant Garamond',Georgia,serif;font-style:italic;color:#cdbfa8;font-size:1.25rem;line-height:2.2;white-space:pre-line;margin-bottom:3rem;"></div>
      <p id="modal-poem-reflection" style="font-family:'Inter',sans-serif;font-size:0.88rem;color:#7a6f63;line-height:1.9;border-top:1px solid #2a2520;padding-top:2rem;font-weight:300;"></p>
    </div>
  </div>

  <slot />

  <footer>
    <p style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#3a3028;font-size:1rem;margin-bottom:0.5rem;">chaos with clarity</p>
    <div class="footer-divider"></div>
    <p style="font-size:0.7rem;letter-spacing:0.1em;color:#3a3028;">© 2026 Chaos With Clarity · Abby Jain</p>
    <div class="footer-links">
      <a href="https://instagram.com/iamabbyjain" target="_blank" rel="noopener" aria-label="Instagram @iamabbyjain">@iamabbyjain</a>
      <a href="https://youtube.com/@iamabbyjain" target="_blank" rel="noopener" aria-label="YouTube @iamabbyjain">YouTube</a>
    </div>
  </footer>

  <script>
    const nav = document.getElementById('site-nav');
    window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', window.scrollY > 40));
    const modal = document.getElementById('poem-modal');
    const closeBtn = document.getElementById('close-poem-modal');
    document.querySelectorAll('[data-open-poem]').forEach(btn => {
      btn.addEventListener('click', () => {
        const card = btn.closest('[data-poem-card]');
        if (!card || !modal) return;
        document.getElementById('modal-poem-title').textContent = card.dataset.title || '';
        document.getElementById('modal-poem-date').textContent = card.dataset.date || '';
        document.getElementById('modal-poem-body').textContent = card.dataset.poem || '';
        document.getElementById('modal-poem-reflection').textContent = card.dataset.reflection || '';
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });
    closeBtn?.addEventListener('click', () => { modal?.classList.remove('open'); document.body.style.overflow = ''; });
    modal?.addEventListener('click', e => { if (e.target === modal) { modal.classList.remove('open'); document.body.style.overflow = ''; } });
  </script>
</body>
</html>
