---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Chaos With Clarity | Abby"
  description="Short, honest ideas about ego, experience, and being fully alive — for people who think too much and feel even more."
>

  <!-- ══ HERO ══════════════════════════════════════════════ -->
  <section style="min-height:100svh;background:var(--bg);display:flex;flex-direction:column;justify-content:center;padding:8rem 3rem 5rem;position:relative;overflow:hidden;">
    <!-- background video — loops first 5 sec via JS below -->
    <video id="hero-vid" autoplay muted loop playsinline style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;opacity:0.45;">
      <source src="/images/abby-video.mp4" type="video/mp4" />
    </video>
    <!-- warm cream overlay so text stays crisp -->
    <div style="position:absolute;inset:0;background:var(--bg);opacity:0.58;z-index:1;pointer-events:none;"></div>

    <div style="max-width:72rem;margin:0 auto;width:100%;position:relative;z-index:2;">
      <p style="font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:2rem;font-weight:600;">Essays · Poetry · Inner Work</p>

      <h1 style="font-family:'Fraunces',serif;letter-spacing:-0.03em;line-height:0.9;margin-bottom:2.5rem;">
        <span style="display:block;font-size:clamp(4rem,10vw,9rem);font-weight:800;color:var(--text);">Chaos</span>
        <span style="display:block;font-size:clamp(1.6rem,3.8vw,3.4rem);font-weight:400;font-style:italic;color:var(--olive-accent);padding-left:clamp(1rem,3vw,3rem);line-height:1.5;">With</span>
        <span style="display:block;font-size:clamp(4rem,10vw,9rem);font-weight:800;color:var(--text);">Clarity</span>
      </h1>

      <p style="color:var(--text-muted);font-size:clamp(0.95rem,1.8vw,1.1rem);line-height:2.1;max-width:36rem;margin-bottom:1.5rem;font-weight:300;border-left:2px solid var(--border);padding-left:1.25rem;">
        Short, honest ideas about ego, experience, and being fully alive.<br/>
        <em style="color:var(--olive-accent);font-style:italic;">For people who think too much and feel even more.</em>
      </p>

      <p style="color:var(--text-muted);font-size:0.95rem;max-width:36rem;line-height:1.9;margin-bottom:3rem;font-weight:300;">
        I'm Abby, a writer and creator who turns the mess of everyday life into lines that make you pause, breathe, and see differently. This is the calm corner of the internet where we slow down, question everything, and leave a little lighter than we arrived.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;">
        <a href="/writings" style="display:inline-block;background:var(--olive-accent);color:var(--text-on-dark);font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--olive-accent)'">Read the Writing</a>
        <a href="https://youtube.com/@iamabbyjain" target="_blank" rel="noopener" style="display:inline-block;border:1px solid var(--border);color:var(--text-muted);font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Watch the Reels</a>
        <a href="/join" style="display:inline-block;border:1px solid var(--border);color:var(--text-muted);font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Get the Letters</a>
      </div>
    </div>
  </section>

  <!-- ══ THIS SPACE IS FOR YOU ══════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:6rem 3rem;background:var(--bg-alt);">
    <div style="display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start;" class="for-you-grid">
      <div style="position:sticky;top:7rem;">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:1rem;font-weight:600;">This space is for you if</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;color:var(--text);line-height:1.05;">You feel it<br/><em style="font-weight:400;color:var(--text-muted);">before you<br/>name it.</em></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          "You're tired of empty motivation and want depth without the jargon.",
          "You overthink, feel a lot, and secretly like that about yourself.",
          "You're curious about mindfulness, but allergic to perfectionism and spiritual performance.",
          "You want to own fewer things, carry less ego, and experience more life."
        ].map((line, i) => (
          <div style={`padding:2rem 0;border-bottom:1px solid var(--border);${i===0?'border-top:1px solid var(--border);':''}`}>
            <p style="font-size:1rem;color:var(--text);font-weight:500;line-height:1.65;">{line}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ FEATURED POEM ══════════════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:6rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);" class="poem-home-grid">

      <article style="padding:3.5rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:1.25rem;"
               data-poem-card
               data-title="Unstruck Silence (Anhat Nad)"
               data-date="March 2026"
               data-poem="It starts but never ends,
It is just life, nothing to amend.

Silence is louder than noise,
Once you hear it, it abides.

Anhat Nad, it is said,
The uncreated sound that spreads.
Not from anywhere near or far,
Always present, revealing scars.

Contradiction is life's way of being,
Fighting it is simply fleeing.

Give your heart a pause,
Breathe in and listen to the cosmos.
It enters you and penetrates deep,
Making every restless cell sleep.

I know it sounds absurd,
That is why words feel blurred.

It starts but never ends,
It is just life, nothing to amend.

Empty the weight you carry in your heart,
Just be, and let silence be the start.

A start not of something new,
But something in you you always knew.

You are so small, yet vast the roles you play,
Trying to be more as life slips away.

To be ahead is just a muse,
Your breaths are counted, if you choose to view.

See what you truly hold,
Let go of wanting, and be bold.

Let silence become your home,
Be less, not more.

Be less, not more."
               data-reflection="">
        <p style="font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--olive-accent);font-weight:600;">Featured Poem · March 2026</p>
        <h3 style="font-family:'Fraunces',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--text);line-height:1.15;">Unstruck Silence<br/><em style="font-weight:400;font-size:0.8em;color:var(--text-muted);">(Anhat Nad)</em></h3>
        <div style="font-family:'Fraunces',serif;font-style:italic;color:var(--text-muted);font-size:1.05rem;line-height:2.2;border-left:3px solid var(--olive-accent);padding-left:1.5rem;flex:1;">
          <p>It starts but never ends,</p>
          <p>It is just life, nothing to amend.</p>
          <p>Silence is louder than noise,</p>
          <p>Once you hear it, it abides.</p>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <span style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--olive-accent);font-weight:600;">Click to read</span>
          <i class="ph ph-arrow-right" style="color:var(--olive-accent);font-size:0.9rem;"></i>
        </div>
      </article>

      <div style="background:var(--bg-alt);padding:3.5rem;display:flex;flex-direction:column;justify-content:space-between;gap:2rem;">
        <div>
          <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:1.5rem;font-weight:600;">About this space</p>
          <p style="font-family:'Fraunces',serif;font-size:1.4rem;font-weight:500;color:var(--text);line-height:1.5;margin-bottom:1.25rem;">
            "Spreadsheets couldn't answer the chest ache. So I write."
          </p>
          <p style="font-size:0.92rem;color:var(--text-muted);line-height:1.9;">Nine years of finance, from EY audit rooms to sitting across from founders who had everything and felt nothing, taught me one thing: clarity without depth is just noise with good formatting.</p>
        </div>
        <div>
          <a href="/about" style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:0.75rem 1.75rem;display:inline-block;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">About Abby →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ NEWSLETTER CTA ══════════════════════════════════════ -->
  <section style="background:var(--olive-accent);padding:6rem 3rem;">
    <div style="max-width:50rem;margin:0 auto;text-align:center;">
      <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-light);margin-bottom:1.5rem;font-weight:600;">The Letters</p>
      <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:var(--text-on-dark);line-height:1.05;margin-bottom:1.5rem;">
        Honest notes from<br/><em style="font-weight:400;color:var(--olive-light);">the middle of it all.</em>
      </h2>
      <p style="color:#c8c8a0;font-size:0.95rem;line-height:1.9;max-width:36rem;margin:0 auto 2.5rem;font-weight:300;">
        Thoughts I don't share on Instagram or YouTube. Drafts, behind-the-scenes process, questions I'm still figuring out. No spam. No "daily grind" tips. Just honest notes.
      </p>
      <a href="/join" style="display:inline-block;background:var(--bg);color:var(--olive-accent);font-size:0.76rem;letter-spacing:0.18em;text-transform:uppercase;padding:1.1rem 2.5rem;text-decoration:none;font-weight:700;transition:background 0.2s;" onmouseover="this.style.background='var(--bg-alt)'" onmouseout="this.style.background='var(--bg)'">Get the Letters</a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 768px) {
    .for-you-grid { grid-template-columns: 1fr !important; gap: 2.5rem !important; background: var(--bg-alt) !important; }
    .for-you-grid > div:first-child { position: static !important; }
    .poem-home-grid { grid-template-columns: 1fr !important; }
    .poem-home-grid > article { border-right: none !important; border-bottom: 1px solid var(--border) !important; }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.5rem !important; padding-right: 1.5rem !important; }
  }
</style>

<script>
  // Loop only the first 5 seconds of the hero video
  const vid = document.getElementById('hero-vid');
  if (vid) {
    vid.addEventListener('timeupdate', () => {
      if (vid.currentTime >= 5) vid.currentTime = 0;
    });
  }
</script>
