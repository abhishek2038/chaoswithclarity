---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Poetry | Chaos With Clarity"
  description="Poetry collections and chapbooks by Abby — available as digital downloads."
>

  <!-- ══ PAGE HEADER ══════════════════════════════════════════ -->
  <section class="page-header">
    <div class="page-header-inner">
      <p class="overline" style="color:var(--gold);">Digital Downloads</p>
      <h1 class="page-h1">Poetry<br/>Collections</h1>
      <div class="header-rule"></div>
      <p class="page-sub">
        Forty poems. Two series. Five themes.<br class="br-d"/>
        Take them with you.
      </p>
    </div>
    <p class="header-bg-word" aria-hidden="true">poems</p>
  </section>

  <div class="shop-wrap">

    <!-- ══ FEATURED: FULL COLLECTION ══════════════════════════ -->
    <section class="shop-section">
      <div class="section-head">
        <p class="section-label" style="color:var(--gold);">Full Collection</p>
      </div>

      <div class="featured-card">
        <div class="featured-text">
          <p class="product-tag">Digital PDF · 84 pages</p>
          <h2 class="product-title">Chaos With Clarity<br/><em class="product-subtitle">A Collection of Poems</em></h2>
          <p class="product-desc">
            Forty poems written between 2024 and 2026 — on mortality, ego, meditation, pain,
            freedom, and love. Includes the complete Mirror Trilogy and Forest of Consciousness
            series, with reflections on the arc of each.
          </p>
          <ul class="product-list">
            <li>5 thematic sections</li>
            <li>2 named series with author reflections</li>
            <li>A note from the author</li>
            <li>Beautifully typeset, A5 format</li>
          </ul>
          <div class="product-price-row">
            <p class="product-price">$9</p>
            <p class="product-price-note">One-time · Yours to keep</p>
          </div>
          <!-- Replace href with your Gumroad link -->
          <a href="https://gumroad.com" target="_blank" rel="noopener" class="buy-btn">
            Get the Collection →
          </a>
        </div>
        <div class="featured-cover">
          <div class="book-cover">
            <p class="book-cover-title">CHAOS<br/>WITH<br/>CLARITY</p>
            <div class="book-cover-rule"></div>
            <p class="book-cover-sub">A Collection of Poems</p>
            <p class="book-cover-author">Abby</p>
            <p class="book-cover-num">40 Poems</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ FREE CHAPBOOKS ══════════════════════════════════════ -->
    <section class="shop-section">
      <div class="section-head">
        <p class="section-label" style="color:var(--olive-bright);">Free Chapbooks</p>
        <p class="section-note">No email required. Just download and read.</p>
      </div>

      <div class="chapbook-grid">

        <!-- Mirror Trilogy -->
        <div class="chapbook-card">
          <div class="chapbook-spine" style="background:var(--gold);"></div>
          <div class="chapbook-body">
            <p class="product-tag">3 poems · Free</p>
            <h3 class="chapbook-title">The Mirror</h3>
            <p class="chapbook-series">A Trilogy in Three Parts</p>
            <p class="chapbook-desc">
              Language. Reflection. Sight. Three poems written on the same day,
              tracing the filters we carry everywhere — and the ones we spend
              our lives trying to see through clearly.
            </p>
            <div class="chapbook-poems">
              <span>I · Beyond Words</span>
              <span>II · The Mirror</span>
              <span>III · The Right Eyes</span>
            </div>
            <a href="/downloads/TheMirror_Trilogy.pdf" download class="free-btn">
              Download Free →
            </a>
          </div>
        </div>

        <!-- Forest of Consciousness -->
        <div class="chapbook-card">
          <div class="chapbook-spine" style="background:var(--olive-bright);"></div>
          <div class="chapbook-body">
            <p class="product-tag">4 poems · Free</p>
            <h3 class="chapbook-title">Forest of Consciousness</h3>
            <p class="chapbook-series">A Four-Part Series</p>
            <p class="chapbook-desc">
              The seed. The self. The forest. The journey. Four poems tracing
              the arc from first impulse inward, through the noise of the mind,
              into the journey that has no destination.
            </p>
            <div class="chapbook-poems">
              <span>I · The Seed</span>
              <span>II · I Am That</span>
              <span>III · Forest of Consciousness</span>
              <span>IV · The Journey</span>
            </div>
            <a href="/downloads/ForestOfConsciousness_Chapbook.pdf" download class="free-btn" style="--btn-color:var(--olive-bright);">
              Download Free →
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- ══ POEM CARDS ═════════════════════════════════════════ -->
    <section class="shop-section">
      <div class="section-head">
        <p class="section-label" style="color:var(--text-muted);">Poem Cards</p>
        <p class="section-note">6 poems · Downloadable · Print and frame them.</p>
      </div>

      <div class="cards-row">
        <div class="cards-preview">
          <div class="mock-card" style="--rot:-2deg;">
            <p class="mock-title">The Right Eyes</p>
            <p class="mock-line">Life is beautiful,</p>
            <p class="mock-line">just need the right eyes.</p>
          </div>
          <div class="mock-card" style="--rot:1.5deg;">
            <p class="mock-title">Nothing to Gain</p>
            <p class="mock-line">I am everything</p>
            <p class="mock-line">where there is nothing to gain.</p>
          </div>
          <div class="mock-card" style="--rot:-0.5deg;">
            <p class="mock-title">Just a Man</p>
            <p class="mock-line">I am just a man,</p>
            <p class="mock-line">time to choose to be kind.</p>
          </div>
        </div>
        <div class="cards-info">
          <p class="product-tag">6 A5 cards · PDF download</p>
          <h3 class="chapbook-title">Poem Cards</h3>
          <p class="chapbook-desc">
            Six poems, each on its own landscape card. Print at home,
            put them on your desk, or frame them. The Right Eyes,
            Nothing to Gain, Just a Man, The Search, Bare, A Gloomy Day.
          </p>
          <div class="product-price-row">
            <p class="product-price">$5</p>
            <p class="product-price-note">Print as many times as you like</p>
          </div>
          <!-- Replace href with your Gumroad link -->
          <a href="https://gumroad.com" target="_blank" rel="noopener" class="buy-btn" style="--btn-bg:var(--text-muted);">
            Get the Cards →
          </a>
        </div>
      </div>
    </section>

    <!-- ══ COMING SOON ════════════════════════════════════════ -->
    <section class="shop-section">
      <div class="section-head">
        <p class="section-label" style="color:var(--text-faint);">Coming Soon</p>
      </div>

      <div class="coming-grid">
        <div class="coming-card">
          <p class="coming-tag">Essays</p>
          <h4 class="coming-title">The Essay Collection</h4>
          <p class="coming-desc">Four long essays on ego, attention, technology, and the examined life. Bundled as a single PDF when complete.</p>
          <p class="coming-price">$7 · Est. late 2026</p>
        </div>
        <div class="coming-card">
          <p class="coming-tag">Hindi</p>
          <h4 class="coming-title">Hindi Poems</h4>
          <p class="coming-desc">A separate collection of poems originally written in Hindi — an underserved voice in the poetry world.</p>
          <p class="coming-price">Coming soon</p>
        </div>
      </div>
    </section>

    <!-- ══ BOTTOM CTA ═════════════════════════════════════════ -->
    <div class="shop-cta">
      <p class="shop-cta-text">Want poems in your inbox before they become products?</p>
      <a href="/join" class="buy-btn">Get the Letters →</a>
    </div>

  </div>
</Layout>

<style>
  /* ── PAGE HEADER ─────────────────────────────────────────── */
  .page-header {
    padding: 10rem 3rem 6rem;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    position: relative; overflow: hidden;
  }
  .page-header-inner { max-width: 72rem; margin: 0 auto; position: relative; z-index: 2; }
  .overline { font-size: 0.66rem; letter-spacing: 0.32em; text-transform: uppercase; font-weight: 600; margin-bottom: 1.5rem; }
  .page-h1 { font-family: 'Fraunces', serif; font-size: clamp(3.5rem,9vw,8rem); font-weight: 800; color: var(--text); letter-spacing: -0.03em; line-height: 0.9; margin-bottom: 2rem; }
  .header-rule { width: 3rem; height: 3px; background: var(--gold); margin-bottom: 1.75rem; }
  .page-sub { color: var(--text-muted); font-size: 0.95rem; line-height: 1.95; font-weight: 300; max-width: 42rem; }
  .header-bg-word { position: absolute; bottom: -1.5rem; right: -1rem; font-family: 'Fraunces', serif; font-size: clamp(6rem,18vw,16rem); font-weight: 800; color: var(--border); opacity: 0.35; letter-spacing: -0.05em; line-height: 1; user-select: none; pointer-events: none; z-index: 1; }
  .br-d { display: inline; }

  /* ── WRAPPER ─────────────────────────────────────────────── */
  .shop-wrap { max-width: 72rem; margin: 0 auto; padding: 5rem 3rem 7rem; }
  .shop-section { margin-bottom: 5rem; }

  /* ── SECTION HEADS ───────────────────────────────────────── */
  .section-head { margin-bottom: 2.5rem; border-bottom: 1px solid var(--border); padding-bottom: 1rem; display: flex; align-items: baseline; gap: 1.5rem; }
  .section-label { font-family: 'Fraunces', serif; font-size: 1.1rem; font-weight: 700; letter-spacing: 0.01em; }
  .section-note { font-size: 0.82rem; color: var(--text-faint); font-weight: 300; }

  /* ── FEATURED CARD ───────────────────────────────────────── */
  .featured-card { display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: start; background: var(--bg-card); padding: 3.5rem; border-top: 4px solid var(--gold); }
  .product-tag { font-size: 0.63rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-faint); font-weight: 600; margin-bottom: 1rem; }
  .product-title { font-family: 'Fraunces', serif; font-size: 2.2rem; font-weight: 800; color: var(--text); line-height: 1.1; margin-bottom: 1.25rem; }
  .product-subtitle { font-weight: 400; font-style: italic; font-size: 1.3rem; color: var(--text-muted); }
  .product-desc { color: var(--text-muted); font-size: 0.93rem; line-height: 1.95; margin-bottom: 1.5rem; max-width: 38rem; }
  .product-list { list-style: none; padding: 0; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .product-list li { font-size: 0.85rem; color: var(--text-muted); padding-left: 1rem; position: relative; }
  .product-list li::before { content: '—'; position: absolute; left: 0; color: var(--gold); }
  .product-price-row { display: flex; align-items: baseline; gap: 1rem; margin-bottom: 1.75rem; }
  .product-price { font-family: 'Fraunces', serif; font-size: 2.8rem; font-weight: 800; color: var(--gold); line-height: 1; }
  .product-price-note { font-size: 0.78rem; color: var(--text-faint); }
  .buy-btn { display: inline-block; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; background: var(--btn-bg, var(--gold)); color: var(--text-on-dark); padding: 1rem 2.25rem; text-decoration: none; font-weight: 700; transition: opacity 0.2s, transform 0.2s; }
  .buy-btn:hover { opacity: 0.85; transform: translateY(-2px); }

  /* ── BOOK COVER MOCK ─────────────────────────────────────── */
  .featured-cover { flex-shrink: 0; }
  .book-cover { width: 140px; background: #06050a; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; border-left: 5px solid var(--gold); min-height: 200px; justify-content: center; }
  .book-cover-title { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 800; color: var(--text, #f0ebe0); line-height: 1.1; letter-spacing: -0.01em; }
  .book-cover-rule { width: 2rem; height: 2px; background: var(--gold); }
  .book-cover-sub { font-size: 0.65rem; color: #c0a878; font-style: italic; }
  .book-cover-author { font-size: 0.72rem; color: var(--gold); margin-top: 0.5rem; }
  .book-cover-num { font-size: 0.6rem; color: #7a6a52; letter-spacing: 0.15em; text-transform: uppercase; margin-top: auto; padding-top: 1.5rem; }

  /* ── CHAPBOOKS GRID ──────────────────────────────────────── */
  .chapbook-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .chapbook-card { display: flex; background: var(--bg-card); overflow: hidden; }
  .chapbook-spine { width: 5px; flex-shrink: 0; }
  .chapbook-body { padding: 2.5rem; flex: 1; }
  .chapbook-title { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 800; color: var(--text); margin-bottom: 0.25rem; }
  .chapbook-series { font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--text-faint); margin-bottom: 1rem; }
  .chapbook-desc { color: var(--text-muted); font-size: 0.88rem; line-height: 1.9; margin-bottom: 1.25rem; }
  .chapbook-poems { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 1.75rem; }
  .chapbook-poems span { font-size: 0.78rem; color: var(--text-faint); font-style: italic; }
  .free-btn { display: inline-block; font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--btn-color, var(--gold)); border: 1px solid var(--btn-color, var(--gold)); padding: 0.7rem 1.5rem; text-decoration: none; font-weight: 700; transition: background 0.2s, color 0.2s; }
  .free-btn:hover { background: var(--btn-color, var(--gold)); color: var(--text-on-dark); }

  /* ── POEM CARDS ROW ──────────────────────────────────────── */
  .cards-row { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
  .cards-preview { display: flex; flex-direction: column; gap: 0; position: relative; height: 220px; }
  .mock-card { position: absolute; background: #FAF7F2; border: 1px solid var(--border); padding: 1.25rem 1.5rem; width: 85%; box-shadow: 0 4px 20px rgba(0,0,0,0.12); border-left: 3px solid var(--gold); }
  .mock-card:nth-child(1) { top: 0; left: 0; transform: rotate(var(--rot)); z-index: 3; }
  .mock-card:nth-child(2) { top: 30px; left: 20px; transform: rotate(var(--rot)); z-index: 2; }
  .mock-card:nth-child(3) { top: 60px; left: 40px; transform: rotate(var(--rot)); z-index: 1; }
  .mock-title { font-family: 'Fraunces', serif; font-size: 0.82rem; font-weight: 700; color: #1A1610; margin-bottom: 0.4rem; }
  .mock-line { font-family: Georgia, serif; font-style: italic; font-size: 0.75rem; color: #7A6A52; line-height: 1.6; }

  /* ── COMING SOON ─────────────────────────────────────────── */
  .coming-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .coming-card { background: var(--bg-card); padding: 2rem 2.5rem; border-top: 2px dashed var(--border); }
  .coming-tag { font-size: 0.6rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--text-faint); font-weight: 600; margin-bottom: 0.75rem; }
  .coming-title { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 700; color: var(--text-muted); margin-bottom: 0.75rem; }
  .coming-desc { color: var(--text-faint); font-size: 0.85rem; line-height: 1.85; margin-bottom: 1rem; }
  .coming-price { font-size: 0.72rem; letter-spacing: 0.12em; color: var(--text-faint); font-style: italic; }

  /* ── BOTTOM CTA ──────────────────────────────────────────── */
  .shop-cta { border-top: 1px solid var(--border); padding-top: 4rem; text-align: center; }
  .shop-cta-text { font-family: 'Fraunces', serif; font-style: italic; color: var(--text-muted); font-size: 1.2rem; margin-bottom: 2rem; }

  /* ── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 960px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-cover { display: none; }
    .chapbook-grid { grid-template-columns: 1fr; }
    .cards-row { grid-template-columns: 1fr; }
    .cards-preview { display: none; }
    .coming-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 580px) {
    .shop-wrap { padding-left: 1.5rem; padding-right: 1.5rem; }
    .page-header { padding-left: 1.5rem; padding-right: 1.5rem; }
    .header-bg-word { display: none; }
    .br-d { display: none; }
  }
</style>
