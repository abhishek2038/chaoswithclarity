---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Offerings | Chaos With Clarity" description="Work with Abby: free letters, essays, and reflections — plus 1:1 Soul + Strategy sessions, Chaos Circles, and a poetry collection.">

  <!-- HEADER -->
  <section style="padding:10rem 3rem 6rem;background:var(--bg-alt);border-bottom:1px solid var(--border);">
    <div style="max-width:72rem;margin:0 auto;">
      <p style="font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--olive-accent);margin-bottom:1.5rem;font-weight:600;">Work with Abby</p>
      <h1 style="font-family:'Fraunces',serif;font-size:clamp(3.5rem,9vw,8rem);font-weight:800;color:var(--text);letter-spacing:-0.03em;line-height:0.9;">Offerings</h1>
      <p style="color:var(--text-muted);font-size:1rem;line-height:1.9;max-width:44rem;margin-top:2rem;font-weight:300;">
        Start free, go as deep as you want. Some things are here whenever you need them. Others are for when you're ready to go further.
      </p>
    </div>
  </section>

  <!-- ══ FREE SECTION ══════════════════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:6rem 3rem 3rem;">
    <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:4rem;">
      <div style="flex:1;height:1px;background:var(--border);"></div>
      <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--text-muted);padding:0 1rem;white-space:nowrap;font-weight:600;">Free to start</p>
      <div style="flex:1;height:1px;background:var(--border);"></div>
    </div>
  </section>

  <!-- F1: Letters from the Runway -->
  <section style="max-width:72rem;margin:0 auto;padding:0 3rem 5rem;">
    <div style="display:grid;grid-template-columns:3fr 2fr;gap:4rem;align-items:start;" class="offering-grid">
      <div>
        <p style="font-family:'Fraunces',serif;font-size:clamp(4rem,8vw,7rem);color:var(--bg-alt);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.04em;">F1</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3rem);color:var(--text);font-weight:700;margin-bottom:1.5rem;line-height:1.1;">Letters from the Runway</h2>
        <p style="color:var(--text-muted);font-size:0.97rem;line-height:2.1;margin-bottom:1.5rem;max-width:38rem;">
          Slow, honest emails about money, meaning, ego, work, and "enough". Occasional letters where I share a story from my finance days, one clear idea, and one question to sit with — the kind you can't answer in a spreadsheet but can't ignore either.
        </p>
        <p style="color:var(--text-muted);font-size:0.97rem;line-height:2.1;margin-bottom:2rem;max-width:38rem;">
          <em>For people who have their life "together" on paper but still feel restless, and want depth without jargon or lectures.</em>
        </p>
        <a href="/join" style="display:inline-block;background:var(--olive-accent);color:var(--text-on-dark);font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--olive-accent)'">Get Letters from the Runway</a>
      </div>
      <div style="background:var(--olive-deep);padding:2.5rem;border:1px solid var(--border-dark);">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-light);margin-bottom:1rem;font-weight:600;">What arrives</p>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:1rem;">
          {["A story from 9 years in finance", "One clear idea you can carry", "One question no spreadsheet can answer", "No spam. No daily grind tips."].map(item => (
            <li style="font-size:0.88rem;color:var(--text-dim-dark);display:flex;align-items:flex-start;gap:0.75rem;line-height:1.7;">
              <span style="color:var(--olive-light);font-weight:700;flex-shrink:0;">—</span> {item}
            </li>
          ))}
        </ul>
        <div style="border-top:1px solid var(--border-dark);padding-top:1.25rem;margin-top:1.5rem;">
          <p style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,2.8rem);color:var(--olive-bright);font-weight:800;line-height:1;">Free</p>
          <p style="font-size:0.85rem;color:var(--text-dim-dark);margin-top:0.25rem;">Always</p>
        </div>
      </div>
    </div>
  </section>

  <div style="max-width:72rem;margin:0 auto;padding:0 3rem;"><div style="height:1px;background:var(--border);"></div></div>

  <!-- F2 + F3: Library & Chaos Notes -->
  <section style="max-width:72rem;margin:0 auto;padding:5rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);" class="pair-grid">

      <!-- F2: Library -->
      <div style="padding:3rem;border-right:1px solid var(--border);">
        <p style="font-family:'Fraunces',serif;font-size:3.5rem;color:var(--bg-alt);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.03em;">F2</p>
        <h2 style="font-family:'Fraunces',serif;font-size:1.8rem;color:var(--text);font-weight:700;margin-bottom:1rem;line-height:1.15;">Library of Essays &amp; Reels</h2>
        <p style="color:var(--text-muted);font-size:0.92rem;line-height:2;margin-bottom:1.5rem;">A growing archive of work, organised by theme. Each reel is paired with a short written companion so you can sit with the idea, not just scroll past it.</p>
        <ul style="list-style:none;margin-bottom:1.75rem;display:flex;flex-direction:column;gap:0.5rem;">
          {["Ego & Identity","Money, Work & Runway","Technology & AI","Minimalism & Ownership","Reading & Attention"].map(tag => (
            <li style="font-size:0.82rem;color:var(--text-muted);display:flex;align-items:center;gap:0.625rem;font-weight:500;">
              <span style="width:5px;height:5px;border-radius:50%;background:var(--olive-accent);flex-shrink:0;"></span>{tag}
            </li>
          ))}
        </ul>
        <a href="/writings" style="display:inline-block;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--olive-accent);text-decoration:none;border:2px solid var(--olive-accent);padding:0.7rem 1.4rem;font-weight:600;transition:all 0.2s;" onmouseover="this.style.background='var(--olive-accent)';this.style.color='var(--text-on-dark)'" onmouseout="this.style.background='transparent';this.style.color='var(--olive-accent)'">Browse the Library</a>
      </div>

      <!-- F3: Chaos Notes -->
      <div style="padding:3rem;background:var(--bg-alt);">
        <p style="font-family:'Fraunces',serif;font-size:3.5rem;color:var(--border);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.03em;">F3</p>
        <h2 style="font-family:'Fraunces',serif;font-size:1.8rem;color:var(--text);font-weight:700;margin-bottom:1rem;line-height:1.15;">Chaos Notes</h2>
        <p style="color:var(--text-muted);font-size:0.92rem;line-height:2;margin-bottom:1.5rem;">Tiny 1–3 paragraph reflections — quick hits of clarity for when you don't have time for a long essay but still want something real.</p>
        <p style="font-family:'Fraunces',serif;font-style:italic;color:var(--text-muted);font-size:1rem;line-height:1.9;margin-bottom:1.75rem;border-left:3px solid var(--olive-accent);padding-left:1rem;">Snapshots from inside the chaos: small, honest notes you can read in under a minute and carry for days.</p>
        <a href="/writings" style="display:inline-block;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:0.7rem 1.4rem;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Read the Notes</a>
      </div>

    </div>
  </section>

  <!-- ══ PAID SECTION ══════════════════════════════════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:2rem 3rem 3rem;">
    <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:4rem;">
      <div style="flex:1;height:1px;background:var(--border);"></div>
      <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--text-muted);padding:0 1rem;white-space:nowrap;font-weight:600;">Go deeper</p>
      <div style="flex:1;height:1px;background:var(--border);"></div>
    </div>
  </section>

  <!-- 01 SOUL + STRATEGY -->
  <section style="max-width:72rem;margin:0 auto;padding:0 3rem 5rem;">
    <div style="display:grid;grid-template-columns:3fr 2fr;gap:4rem;align-items:start;" class="offering-grid">
      <div>
        <p style="font-family:'Fraunces',serif;font-size:clamp(4rem,8vw,7rem);color:var(--bg-alt);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.04em;">01</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3rem);color:var(--text);font-weight:700;margin-bottom:1.5rem;line-height:1.1;">Soul + Strategy</h2>
        <p style="color:var(--text-muted);font-size:0.97rem;line-height:2.1;margin-bottom:2rem;max-width:36rem;">
          For founders who are financially sharp but emotionally lost. You've built something real — the numbers are there, or close enough. But something inside is off. You're asking questions no spreadsheet can answer: <em>What are we actually optimising for? What's the cost of a life that looks successful but feels empty?</em> This isn't coaching. This isn't therapy. It's a mirror. 90 minutes to see what's actually going on.
        </p>
        <ul style="list-style:none;margin-bottom:2.5rem;">
          {["Finance + inner pattern work", "Lifestyle design that actually fits you", "One-on-one, held with full presence"].map(item => (
            <li style="font-size:0.88rem;color:var(--text-muted);padding:0.7rem 0;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:0.875rem;font-weight:500;">
              <span style="color:var(--olive-accent);font-size:1.1rem;font-weight:700;">—</span> {item}
            </li>
          ))}
        </ul>
        {/* UPDATE THIS LINK: Replace with your actual Calendly URL, e.g. https://calendly.com/abby/soul-strategy */}
        <a href="https://calendly.com/abby/soul-strategy" target="_blank" rel="noopener" style="display:inline-block;background:var(--olive-accent);color:var(--text-on-dark);font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--olive-accent)'">Book a Call</a>
      </div>

      <div style="background:var(--olive-deep);padding:2.5rem;position:sticky;top:7rem;border:1px solid var(--border-dark);">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--olive-light);margin-bottom:1rem;font-weight:600;">Investment</p>
        <p style="font-family:'Fraunces',serif;font-size:clamp(2.5rem,5vw,4rem);color:var(--olive-bright);font-weight:800;line-height:1;margin-bottom:0.5rem;">₹15,000</p>
        <p style="font-size:0.88rem;color:var(--text-dim-dark);margin-bottom:2rem;">Single session · 90 minutes</p>
        <div style="border-top:1px solid var(--border-dark);padding-top:1.5rem;">
          <p style="font-size:0.85rem;color:var(--text-dim-dark);line-height:1.9;">Includes pre-session reflection, the 90-minute call, and a written summary of what surfaced.</p>
        </div>
      </div>
    </div>
  </section>

  <div style="max-width:72rem;margin:0 auto;padding:0 3rem;"><div style="height:1px;background:var(--border);"></div></div>

  <!-- 02 + 03 -->
  <section style="max-width:72rem;margin:0 auto;padding:5rem 3rem;">
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);" class="pair-grid">

      <!-- 02 Chaos Circles -->
      <div style="padding:3rem;border-right:1px solid var(--border);">
        <p style="font-family:'Fraunces',serif;font-size:3.5rem;color:var(--bg-alt);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.03em;">02</p>
        <h2 style="font-family:'Fraunces',serif;font-size:1.8rem;color:var(--text);font-weight:700;margin-bottom:1rem;line-height:1.15;">Chaos Circles</h2>
        <p style="color:var(--text-muted);font-size:0.92rem;line-height:2;margin-bottom:1.5rem;">Six people who are done pretending everything is fine. Six weeks of poems, questions, and the kind of honesty that only happens in small rooms. No fixing. Just witnessing.</p>
        <ul style="list-style:none;margin-bottom:1.75rem;">
          <li style="font-size:0.85rem;color:var(--text-muted);padding:0.4rem 0;display:flex;gap:0.75rem;font-weight:500;"><span style="color:var(--olive-accent);font-weight:700;">—</span> Intimate small group</li>
          <li style="font-size:0.85rem;color:var(--text-muted);padding:0.4rem 0;display:flex;gap:0.75rem;font-weight:500;"><span style="color:var(--olive-accent);font-weight:700;">—</span> A container for real things</li>
        </ul>
        <p style="font-size:0.85rem;color:var(--text);margin-bottom:1.75rem;font-weight:600;">Next circle: <strong style="color:var(--olive-accent);">March 2026</strong></p>
        <a href="/join" style="display:inline-block;font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--olive-accent);text-decoration:none;border:2px solid var(--olive-accent);padding:0.7rem 1.4rem;font-weight:600;transition:all 0.2s;" onmouseover="this.style.background='var(--olive-accent)';this.style.color='var(--text-on-dark)'" onmouseout="this.style.background='transparent';this.style.color='var(--olive-accent)'">Join Waitlist</a>
      </div>

      <!-- 03 Letters from the Edge -->
      <div style="padding:3rem;background:var(--bg-alt);">
        <p style="font-family:'Fraunces',serif;font-size:3.5rem;color:var(--border);font-weight:800;margin-bottom:1.25rem;line-height:1;letter-spacing:-0.03em;">03</p>
        <h2 style="font-family:'Fraunces',serif;font-size:1.8rem;color:var(--text);font-weight:700;margin-bottom:1rem;line-height:1.15;">Letters from the Edge</h2>
        <p style="color:var(--text-muted);font-size:0.92rem;line-height:2;margin-bottom:1.5rem;">A curated collection of poems from three years of writing — on money, mortality, love, and the strange gift of being alive. Something to return to when the noise gets loud.</p>
        <ul style="list-style:none;margin-bottom:1.75rem;">
          <li style="font-size:0.85rem;color:var(--text-muted);padding:0.4rem 0;display:flex;gap:0.75rem;font-weight:500;"><span style="color:var(--gold);font-weight:700;">—</span> Designed for slow, repeated reading</li>
          <li style="font-size:0.85rem;color:var(--text-muted);padding:0.4rem 0;display:flex;gap:0.75rem;font-weight:500;"><span style="color:var(--gold);font-weight:700;">—</span> Your pocket poet for uncertain days</li>
        </ul>
        {/* UPDATE THIS LINK: Replace with your actual Stripe/Gumroad payment link */}
        <a href="https://stripe.com" target="_blank" rel="noopener" style="display:inline-block;background:var(--gold);color:var(--text-on-dark);font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;padding:0.8rem 1.75rem;text-decoration:none;font-weight:600;transition:background 0.2s;" onmouseover="this.style.background='var(--olive-bright)'" onmouseout="this.style.background='var(--gold)'">Buy Now</a>
      </div>

    </div>
  </section>

  <!-- PULL QUOTE + CTA -->
  <section style="max-width:72rem;margin:0 auto;padding:0 3rem 7rem;text-align:center;">
    <div style="border-top:1px solid var(--border);padding-top:4rem;">
      <p style="font-family:'Fraunces',serif;font-size:clamp(1.4rem,3vw,2.2rem);color:var(--text);font-style:italic;line-height:1.7;margin-bottom:0.75rem;font-weight:500;">"Abby's poems land like quiet thunder."</p>
      <p style="font-size:0.7rem;color:var(--text-faint);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:3.5rem;font-weight:600;">— A reader</p>
      <p style="font-size:0.92rem;color:var(--text-muted);margin-bottom:1.5rem;">Not sure which is right for you?</p>
      <a href="/about" style="display:inline-block;font-size:0.72rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-muted);text-decoration:none;border:1px solid var(--border);padding:0.8rem 1.75rem;font-weight:500;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--olive-accent)';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Read About Abby →</a>
    </div>
  </section>

</Layout>

<style>
  @media (max-width: 900px) {
    .offering-grid { grid-template-columns: 1fr !important; }
    .offering-grid > div:last-child { position: static !important; }
    .pair-grid { grid-template-columns: 1fr !important; }
    .pair-grid > div:first-child { border-right: none !important; border-bottom: 1px solid var(--border); }
  }
  @media (max-width: 480px) {
    section { padding-left: 1.5rem !important; padding-right: 1.5rem !important; }
  }
</style>
