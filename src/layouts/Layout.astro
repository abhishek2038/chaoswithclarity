---
export interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Poetry meets founder finance. Soul work for ambition + peace.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <script src="https://unpkg.com/@phosphor-icons/web@2.1.1/src/index.js" is:inline></script>
</head>

<body>

  <!-- ======= HEADER ======= -->
  <header id="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">Chaos With Clarity</a>

      <nav class="desktop-nav">
        <a href="/" class={currentPath === '/' ? 'nav-link active' : 'nav-link'}>Home</a>
        <a href="/writings" class={currentPath.startsWith('/writings') ? 'nav-link active' : 'nav-link'}>Writings</a>
        <a href="/offerings" class={currentPath.startsWith('/offerings') ? 'nav-link active' : 'nav-link'}>Offerings</a>
        <a href="/about" class={currentPath.startsWith('/about') ? 'nav-link active' : 'nav-link'}>About</a>
        <a href="/join" class="nav-join">Join</a>
      </nav>

      <button id="menu-btn" class="menu-btn" aria-label="Open menu">
        <i class="ph ph-list"></i>
      </button>
    </div>

    <div id="mobile-nav" class="mobile-nav hidden">
      <a href="/" class="mobile-link">Home</a>
      <a href="/writings" class="mobile-link">Writings</a>
      <a href="/offerings" class="mobile-link">Offerings</a>
      <a href="/about" class="mobile-link">About</a>
      <a href="/join" class="mobile-link mobile-join">Join</a>
    </div>
  </header>

  <!-- ======= MAIN ======= -->
  <main>
    <slot />
  </main>

  <!-- ======= FOOTER ======= -->
  <footer>
    <div class="footer-inner">
      <p class="footer-copy">© 2026 Chaos With Clarity</p>
      <div class="footer-links">
        <a href="https://instagram.com/chaoswithclarity" target="_blank" rel="noopener" class="footer-link">
          <i class="ph ph-instagram-logo"></i> Instagram
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener" class="footer-link">
          <i class="ph ph-youtube-logo"></i> YouTube
        </a>
        <a href="https://abbyjain.com" target="_blank" rel="noopener" class="footer-link">
          abbyjain.com ↗
        </a>
      </div>
    </div>
  </footer>

  <!-- ======= POEM MODAL (kept dark for contrast) ======= -->
  <div id="poem-modal" style="display:none; position:fixed; inset:0; z-index:200; align-items:center; justify-content:center; padding:1rem;">
    <div id="modal-backdrop" style="position:absolute; inset:0; background:rgba(28,24,20,0.82); backdrop-filter:blur(6px);"></div>
    <div style="position:relative; z-index:10; background:#1a1714; border:1px solid #302a24; width:100%; max-width:42rem; max-height:90vh; overflow-y:auto; padding:3rem 2.5rem;">
      <button id="modal-close" style="position:absolute; top:1.25rem; right:1.25rem; background:none; border:none; cursor:pointer; color:#7a7268; font-size:1.25rem;" onmouseover="this.style.color='#e8e3d8'" onmouseout="this.style.color='#7a7268'">
        <i class="ph ph-x"></i>
      </button>
      <p id="modal-date" style="font-size:0.65rem; letter-spacing:0.28em; text-transform:uppercase; color:#7a7268; margin-bottom:0.75rem;"></p>
      <h2 id="modal-title" style="font-family:'Playfair Display',serif; font-size:1.75rem; color:#e8e3d8; margin-bottom:2rem; line-height:1.2;"></h2>
      <div id="modal-body" style="font-family:'Playfair Display',serif; font-style:italic; color:rgba(232,227,216,0.9); line-height:2.1; font-size:1.05rem;"></div>
      <div id="modal-reflection" style="margin-top:2.5rem; border-left:2px solid #9a7058; padding-left:1.25rem; display:none;">
        <p style="font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; color:#9a7058; margin-bottom:0.5rem;">Reflection</p>
        <p id="modal-reflection-text" style="color:#7a7268; font-size:0.88rem; line-height:1.8;"></p>
      </div>
      <div style="margin-top:2.5rem; display:flex; flex-wrap:wrap; gap:0.75rem;">
        <a href="/writings" style="font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; border:1px solid #302a24; color:#7a7268; padding:0.75rem 1.25rem; transition:all 0.2s;" onmouseover="this.style.borderColor='#9a7058'; this.style.color='#9a7058'" onmouseout="this.style.borderColor='#302a24'; this.style.color='#7a7268'">← All Poems</a>
        <button id="modal-share" style="font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; border:1px solid #302a24; color:#7a7268; padding:0.75rem 1.25rem; background:none; cursor:pointer; display:flex; align-items:center; gap:0.5rem; transition:all 0.2s;" onmouseover="this.style.borderColor='#9a7058'; this.style.color='#9a7058'" onmouseout="this.style.borderColor='#302a24'; this.style.color='#7a7268'"><i class="ph ph-share-network"></i> Share</button>
        <a href="/join" style="font-size:0.65rem; letter-spacing:0.25em; text-transform:uppercase; background:#9a7058; color:#f2e8dc; padding:0.75rem 1.25rem; transition:opacity 0.2s;" onmouseover="this.style.opacity='0.85'" onmouseout="this.style.opacity='1'">Join the List</a>
      </div>
    </div>
  </div>


  <script>
    // ── Header scroll ──
    const header = document.getElementById('site-header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('scrolled');
      } else {
        header?.classList.remove('scrolled');
      }
    });

    // ── Mobile menu ──
    const menuBtn  = document.getElementById('menu-btn');
    const mobileNav = document.getElementById('mobile-nav');
    menuBtn?.addEventListener('click', () => {
      const isHidden = mobileNav?.classList.toggle('hidden');
      const icon = menuBtn.querySelector('i');
      if (icon) icon.className = isHidden ? 'ph ph-list' : 'ph ph-x';
    });

    // ── Poem modal ──
    const modal       = document.getElementById('poem-modal');
    const backdrop    = document.getElementById('modal-backdrop');
    const modalClose  = document.getElementById('modal-close');
    const modalDate   = document.getElementById('modal-date');
    const modalTitle  = document.getElementById('modal-title');
    const modalBody   = document.getElementById('modal-body');
    const modalRefl   = document.getElementById('modal-reflection');
    const modalReflTx = document.getElementById('modal-reflection-text');
    const modalShare  = document.getElementById('modal-share');

    function openModal(card: HTMLElement) {
      if (modalDate)  modalDate.textContent  = card.dataset.date  || '';
      if (modalTitle) modalTitle.textContent = card.dataset.title || '';
      if (modalBody) {
        const poem = card.dataset.poem || '';
        modalBody.innerHTML = poem.split('\n').map(line =>
          line.trim() === '' ? '<br>' : `<span>${line}</span>`
        ).join('<br>');
      }
      const reflection = card.dataset.reflection || '';
      if (modalReflTx) modalReflTx.textContent = reflection;
      if (modalRefl)   modalRefl.style.display = reflection ? 'block' : 'none';
      if (modal) modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (modal) modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('[data-open-poem]');
      if (btn) {
        const card = (btn as HTMLElement).closest('[data-title]') as HTMLElement;
        if (card) openModal(card);
      }
    });

    backdrop?.addEventListener('click', closeModal);
    modalClose?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    modalShare?.addEventListener('click', () => {
      if (navigator.share) navigator.share({ url: window.location.href });
      else navigator.clipboard.writeText(window.location.href).then(() => alert('Link copied!'));
    });

    // ── Scroll reveal ──
    if ('IntersectionObserver' in window) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.08 });
      document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
    }
  </script>


  <style is:global>
    /* ── CSS CUSTOM PROPERTIES ── */
    :root {
      --bg:           #f2e8dc;
      --bg-alt:       #ece3d5;
      --surface:      #e3d8c8;
      --border:       #cfc3b0;
      --text:         #1c1814;
      --muted:        #7a7268;
      --dim:          #a09888;
      --accent:       #9a7058;
      --accent-warm:  #c9a28a;
      --sage:         #3d6458;
      --sage-light:   #6b9080;
    }

    /* ── BASE ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      font-weight: 300;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      min-height: 100vh;
    }
    a    { color: inherit; text-decoration: none; }
    img  { max-width: 100%; display: block; }

    /* Grain */
    body::after {
      content: ''; position: fixed; inset: 0;
      pointer-events: none; z-index: 9999; opacity: 0.022;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size: 200px;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

    /* ── HEADER ── */
    #site-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
    }
    #site-header.scrolled {
      background: rgba(242, 232, 220, 0.93);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }
    .header-inner {
      max-width: 72rem; margin: 0 auto;
      padding: 0 2rem; height: 4rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .site-logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.05rem; color: var(--text);
      font-weight: 500; letter-spacing: 0.01em;
      transition: color 0.2s;
    }
    .site-logo:hover { color: var(--accent); }
    .desktop-nav { display: none; align-items: center; gap: 2rem; }
    @media (min-width: 768px) { .desktop-nav { display: flex; } }
    .nav-link {
      font-size: 0.82rem; color: var(--muted);
      font-weight: 400; letter-spacing: 0.01em; transition: color 0.2s;
    }
    .nav-link:hover, .nav-link.active { color: var(--text); }
    .nav-join {
      font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase;
      border: 1px solid var(--accent); color: var(--accent);
      padding: 0.45rem 1rem; font-weight: 400; transition: all 0.2s;
    }
    .nav-join:hover { background: var(--accent); color: var(--bg); }
    .menu-btn {
      display: flex; background: none; border: none;
      color: var(--text); font-size: 1.5rem; padding: 0.25rem; cursor: pointer;
    }
    @media (min-width: 768px) { .menu-btn { display: none; } }
    .mobile-nav {
      background: var(--bg-alt); border-top: 1px solid var(--border);
      padding: 1.5rem 2rem 2rem;
      display: flex; flex-direction: column; gap: 1.25rem;
    }
    .mobile-nav.hidden { display: none; }
    .mobile-link { font-size: 0.9rem; color: var(--text); transition: color 0.2s; }
    .mobile-link:hover { color: var(--accent); }
    .mobile-join {
      font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase;
      border: 1px solid var(--accent); color: var(--accent);
      padding: 0.6rem 1rem; width: fit-content; transition: all 0.2s;
    }
    .mobile-join:hover { background: var(--accent); color: var(--bg); }

    /* ── FOOTER ── */
    footer { border-top: 1px solid var(--border); margin-top: 6rem; padding: 3rem 0; }
    .footer-inner {
      max-width: 72rem; margin: 0 auto; padding: 0 2rem;
      display: flex; flex-direction: column; gap: 1rem; align-items: center; text-align: center;
    }
    @media (min-width: 768px) { .footer-inner { flex-direction: row; justify-content: space-between; text-align: left; } }
    .footer-copy { font-family: 'Playfair Display', Georgia, serif; font-style: italic; font-size: 0.82rem; color: var(--dim); }
    .footer-links { display: flex; align-items: center; gap: 1.5rem; }
    .footer-link { font-size: 0.8rem; color: var(--muted); display: flex; align-items: center; gap: 0.35rem; transition: color 0.2s; }
    .footer-link:hover { color: var(--accent); }

    /* ── TYPOGRAPHY UTILS ── */
    .font-serif { font-family: 'Playfair Display', Georgia, serif !important; }
    .eyebrow {
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.65rem; font-weight: 400;
      letter-spacing: 0.3em; text-transform: uppercase;
      color: var(--accent);
    }

    /* ── BUTTONS ── */
    .btn {
      display: inline-block;
      font-family: 'Inter', system-ui, sans-serif;
      font-size: 0.68rem; font-weight: 400;
      letter-spacing: 0.25em; text-transform: uppercase;
      padding: 0.875rem 1.75rem;
      transition: all 0.2s ease;
      white-space: nowrap; cursor: pointer; border: none; background: none;
    }
    .btn-fill  { background: var(--accent); color: var(--bg); }
    .btn-fill:hover { opacity: 0.85; }
    .btn-outline { border: 1px solid var(--accent); color: var(--accent); }
    .btn-outline:hover { background: var(--accent); color: var(--bg); }
    .btn-ghost { border: 1px solid var(--border); color: var(--muted); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

    /* ── REVEAL ── */
    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .reveal.in-view { opacity: 1; transform: translateY(0); }
  </style>

</body>
</html>
