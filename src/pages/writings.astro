---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Writings | Chaos With Clarity" description="All poems by Abby — grouped by theme.">

  <!-- HEADER -->
  <section style="padding:10rem 3rem 5rem;background:#e8dcc8;border-bottom:1px solid #cec5ad;">
    <div style="max-width:72rem;margin:0 auto;">
      <p style="font-size:0.63rem;letter-spacing:0.28em;text-transform:uppercase;color:#5d6b45;margin-bottom:1.5rem;font-weight:400;">All Writings</p>
      <h1 style="font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(3.5rem,8vw,7rem);font-weight:600;color:#1a1612;letter-spacing:-0.02em;line-height:0.9;">Poems</h1>
      <p style="color:#7a7260;font-size:0.85rem;margin-top:1.5rem;letter-spacing:0.06em;">Grouped by theme · newest first</p>
    </div>
  </section>

  <div style="max-width:72rem;margin:0 auto;padding:5rem 3rem 7rem;">

    <!-- ── FREEDOM & OBSERVER ── -->
    <section style="margin-bottom:5rem;">
      <div style="display:flex;align-items:center;gap:1.25rem;margin-bottom:2.5rem;">
        <div style="width:8px;height:8px;border-radius:50%;background:#c17f3a;flex-shrink:0;"></div>
        <h2 style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#c17f3a;font-size:1.3rem;font-weight:400;letter-spacing:0.02em;">Freedom &amp; Observer</h2>
        <div style="flex:1;height:1px;background:#cec5ad;"></div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid #cec5ad;" class="poem-grid-3">

        <!-- Unstruck Silence -->
        <article style="padding:2rem;border-right:1px solid #cec5ad;display:flex;flex-direction:column;gap:1rem;"
                 data-poem-card
                 data-title="Unstruck Silence (Anhat Nad)"
                 data-date="March 2026"
                 data-poem="There is a sound
that was never struck —
no string plucked, no drum hit,
no throat opened to release it.

It was here before you arrived.
It is here after the last thought
you'll ever think
dissolves.

You have heard it in the space
between two breaths —
not the inhale,
not the exhale,
but the pause that holds both,
the way a door frame holds
a house.

You have heard it in the room
after crying stops,
when the chest finally unclenches
and something older than grief
comes through.

The mystics called it Anahata —
unstruck.
The thing that hums
without cause,
loves without reason,
stays without being asked.

You think you have to earn stillness.
You think silence is the reward
for surviving.

But it is not earned.
It is only uncovered —
the way snow uncovers
ground
by melting."
                 data-reflection="Anhat Nad is a concept from Indian classical music and tantra — the sound that was never struck. The Anahata chakra, or heart center, is said to resonate with this unstruck sound. I wrote this after a long meditation session where I kept waiting for something to happen. Nothing did. And then I realized — that was it.">
          <p style="font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:#7a7260;">March 2026</p>
          <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:#1a1612;font-weight:500;line-height:1.3;letter-spacing:0.01em;">Unstruck Silence<br/><span style="font-style:italic;font-weight:400;font-size:1.05rem;color:#7a7260;">(Anhat Nad)</span></h3>
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#7a7260;font-size:1rem;line-height:2.1;flex:1;border-left:2px solid #c17f3a;padding-left:1.25rem;">
            There is a sound<br/>
            that was never struck —<br/>
            no string plucked, no drum hit,<br/>
            no throat opened to release it.
          </p>
          <button data-open-poem style="background:none;border:none;cursor:pointer;font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#c17f3a;font-family:'Inter',sans-serif;padding:0;display:flex;align-items:center;gap:0.4rem;" onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
            Read <i class="ph ph-arrow-right"></i>
          </button>
        </article>

        <!-- Placeholder 2 -->
        <article style="padding:2rem;border-right:1px solid #cec5ad;display:flex;flex-direction:column;gap:1rem;background:#f9f4ed;"
                 data-poem-card
                 data-title="[Poem Title]"
                 data-date=""
                 data-poem=""
                 data-reflection="">
          <p style="font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:#b8ae9a;">[Date]</p>
          <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:#b8ae9a;font-weight:500;">[Poem Title]</h3>
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#b8ae9a;font-size:1rem;line-height:2;flex:1;border-left:2px solid #ddd5be;padding-left:1.25rem;">
            ← Add first 4 lines here →
          </p>
          <span style="font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#b8ae9a;">Add poem</span>
        </article>

        <!-- Placeholder 3 -->
        <article style="padding:2rem;display:flex;flex-direction:column;gap:1rem;background:#f9f4ed;"
                 data-poem-card
                 data-title="[Poem Title]"
                 data-date=""
                 data-poem=""
                 data-reflection="">
          <p style="font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:#b8ae9a;">[Date]</p>
          <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:#b8ae9a;font-weight:500;">[Poem Title]</h3>
          <p style="font-family:'Cormorant Garamond',serif;font-style:italic;color:#b8ae9a;font-size:1rem;line-height:2;flex:1;border-left:2px solid #ddd5be;padding-left:1.25rem;">
            ← Add first 4 lines here →
          </p>
          <span style="font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#b8ae9a;">Add poem</span>
        </article>

      </div>
    </section>

