---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Join the Chaos | Chaos With Clarity" description="Poems, reflections, and circles — sent to your inbox.">

  <!-- FULL-PAGE JOIN HERO -->
  <section class="min-h-screen flex flex-col justify-center items-center text-center px-6 pt-16 relative">

    <div class="w-px h-16 bg-cwc-border mb-10"></div>

    <p class="text-xs tracking-widest uppercase text-cwc-muted mb-4">The List</p>
    <h1 class="font-serif text-4xl md:text-6xl text-cwc-text mb-4">Join the Chaos</h1>
    <p class="font-serif italic text-cwc-accent text-lg mb-10">Poems. Reflections. Circles. Inbox only.</p>

    <p class="text-cwc-muted text-sm max-w-sm leading-relaxed mb-12">
      Every week or so, something lands in your inbox.<br/>
      A poem that names something you couldn't say.<br/>
      A reflection. A question worth sitting with.<br/>
      No filler. No hustle. Just the real stuff.
    </p>

    <!-- Email form — Replace action with your Beehiiv URL -->
    <!--
      TO EMBED BEEHIIV:
      Delete the <form> below and paste your Beehiiv embed snippet here.
    -->
    <form class="flex flex-col sm:flex-row gap-3 w-full max-w-sm" action="#" method="post">
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 bg-cwc-surface border border-cwc-border text-cwc-text text-sm px-5 py-3.5 placeholder-cwc-muted focus:outline-none focus:border-cwc-accent transition-colors"
      />
      <button
        type="submit"
        class="text-xs tracking-widest uppercase bg-cwc-accent text-cwc-bg px-6 py-3.5 hover:bg-cwc-accent-dark transition-colors whitespace-nowrap"
      >
        Send Me Poems
      </button>
    </form>

    <p class="text-cwc-muted/50 text-xs mt-4">No spam. Ever. Unsubscribe any time.</p>

    <blockquote class="mt-16 border-t border-cwc-border pt-8">
      <p class="font-serif italic text-cwc-muted">"Abby's poems land like quiet thunder."</p>
    </blockquote>

    <div class="w-px h-16 bg-cwc-border mt-10"></div>
  </section>


  <!-- WHAT ARRIVES -->
  <section class="max-w-6xl mx-auto px-6 pb-24">

    <div class="flex items-center gap-4 mb-12 reveal">
      <div class="flex-1 h-px bg-cwc-border"></div>
      <p class="text-xs tracking-widest uppercase text-cwc-muted px-4">What arrives</p>
      <div class="flex-1 h-px bg-cwc-border"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-px bg-cwc-border mb-20">

      <div class="bg-cwc-bg p-8 flex flex-col gap-4 reveal">
        <i class="ph ph-pencil-line text-3xl text-cwc-accent"></i>
        <h3 class="font-serif text-lg text-cwc-text">Poems</h3>
        <p class="text-cwc-muted text-sm leading-relaxed">
          New poems as they come — raw, unpolished, honest. The kind of writing
          I'd share with a close friend over chai.
        </p>
      </div>

      <div class="bg-cwc-surface p-8 flex flex-col gap-4 reveal">
        <i class="ph ph-mirror text-3xl text-cwc-muted"></i>
        <h3 class="font-serif text-lg text-cwc-text">Reflections</h3>
        <p class="text-cwc-muted text-sm leading-relaxed">
          The story behind the poem. What was happening. What I was running from.
          What I found when I stopped running.
        </p>
      </div>

      <div class="bg-cwc-bg p-8 flex flex-col gap-4 reveal">
        <i class="ph ph-fire text-3xl text-cwc-sage"></i>
        <h3 class="font-serif text-lg text-cwc-text">Circles</h3>
        <p class="text-cwc-muted text-sm leading-relaxed">
          Occasional invites to Chaos Circles — small group conversations
          for people who want to go deeper than surface.
        </p>
      </div>

    </div>

    <!-- Poem preview slot -->
    <div class="max-w-2xl mx-auto border border-cwc-border p-10 reveal">
      <p class="text-xs tracking-widest uppercase text-cwc-muted mb-2">A taste</p>
      <!--
        ADD A POEM EXCERPT HERE BEFORE LAUNCH
        Replace the placeholder below with 6-8 lines from one of your poems
      -->
      <h3 class="font-serif text-xl text-cwc-text mb-1">[Poem Title]</h3>
      <p class="text-cwc-muted text-xs mb-6">[Date]</p>
      <div class="font-serif italic text-cwc-muted/60 text-sm leading-relaxed border-l border-cwc-border/30 pl-5">
        <p>← Paste a short excerpt of your poem here →</p>
        <p class="mt-1">(6–8 lines works well for a preview)</p>
      </div>
      <a href="/writings"
         class="mt-6 inline-block text-xs tracking-widest uppercase text-cwc-accent hover:text-cwc-text transition-colors">
        Read all poems →
      </a>
    </div>

  </section>

</Layout>
