---
import Layout from '../layouts/Layout.astro';
import { sections, essays } from '../data/poems';
---
<Layout
  title="Writings | Chaos With Clarity"
  description="Essays and poems by Abby — on ego, experience, technology, love, and being fully alive."
>

  <!-- ══ PAGE HEADER ══════════════════════════════════════════ -->
  <section class="page-header">
    <div class="page-header-inner">
      <p class="overline" style="color:var(--olive-accent);">All Writings</p>
      <h1 class="page-h1">Essays<br/>&amp; Poems</h1>
      <div class="header-rule"></div>
      <p class="page-sub">
        Ideas that stay with you the next time you're scrolling at 2am,<br class="br-d"/>
        or wondering why you still feel restless even when everything looks fine on paper.
      </p>
    </div>
    <!-- decorative large word -->
    <p class="header-bg-word" aria-hidden="true">words</p>
  </section>

  <div class="writings-wrap">

    {sections.map((section) => (
      <section class="writings-section" id={section.id}>

        <div class="section-head">
          <p class="section-num" aria-hidden="true">{section.num}</p>
          <div class="section-label-row">
            <span class="section-dot" style={`background:${section.accent};`}></span>
            <h2 class="section-label-text" style={`color:${section.accent};`}>{section.label}</h2>
            <div class="section-line"></div>
          </div>
          {section.subtitle && <p class="section-subtitle">{section.subtitle}</p>}
        </div>

        <div class="poem-grid-3">
          {section.poems.map((poem) => (
            poem.taster ? (
              /* ── TASTER: full poem available in modal ── */
              <article
                class={`poem-card anim-card${poem.series ? ' trilogy-card' : ''}`}
                style={`--card-accent:${section.accent};`}
                data-poem-card
                data-title={poem.subtitle ? `${poem.title} ${poem.subtitle}` : poem.title}
                data-date={poem.date}
                data-poem={poem.text}
                data-reflection={poem.reflection ?? ''}
              >
                {poem.series && (
                  <p class="card-series">
                    {poem.series}{poem.seriesPart ? ` · ${poem.seriesPart}` : ''}
                  </p>
                )}
                <p class="card-date">{poem.date}</p>
                <h3 class="card-title">
                  {poem.title}
                  {poem.subtitle && (
                    <><br/><em class="card-subtitle">{poem.subtitle}</em></>
                  )}
                </h3>
                <div class="card-preview" style={`--prev-color:${section.accent};`}>
                  {poem.preview.map((line) => <p>{line}</p>)}
                </div>
                <span class="card-cta" style={`--cta:${section.accent};`}>
                  Read full poem <i class="ph ph-arrow-right cta-arrow"></i>
                </span>
              </article>
            ) : (
              /* ── NON-TASTER: preview only, drives to shop ── */
              <article
                class={`poem-card anim-card locked-card${poem.series ? ' trilogy-card' : ''}`}
                style={`--card-accent:${section.accent};`}
              >
                {poem.series && (
                  <p class="card-series">
                    {poem.series}{poem.seriesPart ? ` · ${poem.seriesPart}` : ''}
                  </p>
                )}
                <p class="card-date">{poem.date}</p>
                <h3 class="card-title">
                  {poem.title}
                  {poem.subtitle && (
                    <><br/><em class="card-subtitle">{poem.subtitle}</em></>
                  )}
                </h3>
                <div class="card-preview" style={`--prev-color:${section.accent};`}>
                  {poem.preview.slice(0, 2).map((line) => <p>{line}</p>)}
                </div>
                <a href="/poetry" class="card-cta locked-cta" style={`--cta:${section.accent};`}>
                  In the collection →
                </a>
              </article>
            )
          ))}
        </div>

      </section>
    ))}

    <!-- ══ ESSAYS ══════════════════════════════════════════════ -->
    {essays.length > 0 && (
      <section class="writings-section" id="essays">

        <div class="section-head">
          <p class="section-num" aria-hidden="true">VI</p>
          <div class="section-label-row">
            <span class="section-dot" style="background:var(--text-faint);"></span>
            <h2 class="section-label-text" style="color:var(--text-muted);">Essays</h2>
            <div class="section-line"></div>
          </div>
          <p class="section-subtitle">Longer reflections on consciousness, technology, and the examined life.</p>
        </div>

        <div class="essay-grid">
          {essays.map((essay) => (
            essay.status === 'published' && essay.url ? (
              <a href={essay.url} class="essay-card anim-card">
                <p class="essay-tag">Essay</p>
                <h3 class="essay-title">{essay.title}</h3>
                <p class="essay-desc">{essay.description}</p>
                {essay.snippet && <p class="essay-snippet">{essay.snippet}</p>}
              </a>
            ) : (
              <div class="essay-card anim-card">
                <p class="essay-tag">Essay</p>
                <h3 class="essay-title">{essay.title}</h3>
                <p class="essay-desc">{essay.description}</p>
                {essay.snippet && <p class="essay-snippet">{essay.snippet}</p>}
                <span class="essay-soon">Coming soon</span>
              </div>
            )
          ))}
        </div>

      </section>
    )}

    <!-- ══ JOIN CTA ═══════════════════════════════════════════════ -->
    <div class="writings-cta anim-card">
      <p class="writings-cta-quote">
        These pieces arrive in your inbox.<br/>
        <em>Occasional. Honest. Worth it.</em>
      </p>
      <a href="/join" class="cta-btn">Get the Letters &rarr;</a>
    </div>

  </div>
</Layout>

<style>
  /* ══ PAGE HEADER ══════════════════════════════════════════════ */
  .page-header {
    padding: 6rem 3rem 4rem;
    background: var(--bg-alt);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .page-header-inner {
    max-width: 72rem;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .overline {
    font-size: 0.66rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .page-h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin-bottom: 2rem;
  }
  .header-rule {
    width: 3rem;
    height: 3px;
    background: var(--olive-accent);
    margin-bottom: 1.75rem;
  }
  .page-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.95;
    font-weight: 300;
    max-width: 42rem;
  }
  /* large decorative word behind header */
  .header-bg-word {
    position: absolute;
    bottom: -1.5rem;
    right: -1rem;
    font-family: 'Fraunces', serif;
    font-size: clamp(6rem, 18vw, 16rem);
    font-weight: 800;
    color: var(--border);
    opacity: 0.35;
    letter-spacing: -0.05em;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 1;
  }
  .br-d { display: inline; }

  /* ══ WRAPPER ══════════════════════════════════════════════════ */
  .writings-wrap {
    max-width: 72rem;
    margin: 0 auto;
    padding: 4rem 3rem 5rem;
  }
  .writings-section { margin-bottom: 4rem; }

  /* ══ SECTION HEADERS ══════════════════════════════════════════ */
  .section-head { margin-bottom: 3rem; }

  .section-num {
    font-family: 'Fraunces', serif;
    font-size: clamp(4rem, 9vw, 6.5rem);
    font-weight: 800;
    color: var(--border);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: -0.6rem;
    padding-left: 0.1rem;
  }
  .section-label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .section-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .section-label-text {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 0;
  }
  .section-subtitle {
    font-size: 0.85rem;
    color: var(--text-faint);
    margin-top: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.01em;
    font-style: italic;
  }
  .coming-badge {
    font-size: 0.63rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }

  /* ══ POEM CARDS ═══════════════════════════════════════════════ */
  .poem-card {
    background: var(--bg-card);
    background-image: radial-gradient(ellipse at 85% 0%, rgba(184,136,30,0.08) 0%, transparent 60%);
    padding: 3rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    border-top: 4px solid var(--card-accent, var(--olive-accent));
    box-shadow:
      0 2px 20px rgba(42,36,24,0.05),
      0 1px 5px rgba(42,36,24,0.02);
    cursor: pointer;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .poem-card:hover {
    transform: translateY(-9px);
    box-shadow:
      0 22px 60px rgba(42,36,24,0.08),
      0 6px 18px rgba(42,36,24,0.05);
  }

  .card-date {
    font-size: 0.63rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }
  .card-title {
    font-family: 'Fraunces', serif;
    font-size: 1.55rem;
    color: var(--text);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .card-subtitle {
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--text-muted);
  }

  /* Preview with decorative quote mark */
  .card-preview {
    font-family: 'Fraunces', serif;
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.97rem;
    line-height: 2.1;
    flex: 1;
    border-left: 3px solid var(--prev-color, var(--olive-accent));
    padding-left: 1.3rem;
    position: relative;
  }
  .card-preview::before {
    content: '\201C';
    font-family: 'Fraunces', serif;
    font-size: 4rem;
    line-height: 0.6;
    font-style: normal;
    color: var(--border);
    display: block;
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .card-cta {
    font-size: 0.63rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cta, var(--olive-accent));
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .cta-arrow {
    transition: transform 0.25s ease;
  }
  .poem-card:hover .cta-arrow {
    transform: translateX(5px);
  }

  /* ══ LOCKED CARD (non-taster) ════════════════════════════════ */
  .locked-card { opacity: 0.72; cursor: default; }
  .locked-card:hover { border-color: var(--border); transform: none; }
  .locked-cta {
    text-decoration: none;
    color: var(--text-faint);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 600;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  .locked-cta:hover { opacity: 1; }

  /* ══ ESSAY CARDS ══════════════════════════════════════════════ */
  .essay-card {
    background: var(--bg-card);
    padding: 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    border-left: 4px solid var(--border);
    box-shadow: 0 2px 16px rgba(42,36,24,0.04);
    transition:
      border-color 0.3s ease,
      box-shadow 0.35s ease,
      transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
    text-decoration: none;
    color: inherit;
  }
  .essay-card:hover {
    border-left-color: var(--text-faint);
    transform: translateY(-6px);
    box-shadow: 0 14px 40px rgba(42,36,24,0.06);
  }
  .essay-tag {
    font-size: 0.63rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }
  .essay-title {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    color: var(--text);
    font-weight: 700;
    line-height: 1.25;
  }
  .essay-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.9;
  }
  .essay-snippet {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.85;
    font-style: italic;
    opacity: 0.75;
    margin-top: 0.25rem;
    flex: 1;
  }
  .essay-soon {
    font-size: 0.63rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
    font-style: italic;
  }

  /* ══ TRILOGY ══════════════════════════════════════════════════ */
  .card-series {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--olive-accent);
    font-weight: 700;
    opacity: 0.75;
    margin-bottom: -0.5rem;
  }
  .trilogy-card {
    border-top-width: 3px;
    border-top-style: dashed;
  }

  /* ══ SCROLL ANIMATION ═════════════════════════════════════════ */
  .anim-card {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s ease;
  }
  .anim-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .poem-card.anim-card.visible:hover  { transform: translateY(-9px); }
  .essay-card.anim-card.visible:hover { transform: translateY(-6px); }

  /* ══ JOIN CTA ═════════════════════════════════════════════════ */
  .writings-cta {
    border-top: 1px solid var(--border);
    padding-top: 4rem;
    text-align: center;
  }
  .writings-cta-quote {
    font-family: 'Fraunces', serif;
    font-style: italic;
    color: var(--text-muted);
    font-size: 1.3rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .cta-btn {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: var(--olive-accent);
    color: var(--text-on-dark);
    padding: 1rem 2.75rem;
    text-decoration: none;
    font-weight: 700;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .cta-btn:hover {
    background: var(--olive-bright);
    transform: translateY(-2px);
  }

  /* ══ GRIDS ════════════════════════════════════════════════════ */
  .poem-grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .poem-grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .essay-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  /* ══ RESPONSIVE ═══════════════════════════════════════════════ */
  @media (max-width: 960px) {
    .poem-grid-3 { grid-template-columns: 1fr 1fr; }
    .essay-grid  { grid-template-columns: 1fr; }
    .poem-grid-2 { grid-template-columns: 1fr; }
    .br-d { display: none; }
  }
  @media (max-width: 580px) {
    .poem-grid-3 { grid-template-columns: 1fr; }
    .poem-grid-2 { grid-template-columns: 1fr; }
    .writings-wrap { padding-left: 1.5rem; padding-right: 1.5rem; }
    .page-header { padding-left: 1.5rem; padding-right: 1.5rem; }
    .header-bg-word { display: none; }
    .card-title { font-size: 1.3rem; }
  }
</style>

<script>
  // Staggered scroll-fade for all .anim-card elements
  const cards = document.querySelectorAll<HTMLElement>('.anim-card');

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const siblings = [...(entry.target.parentElement?.children ?? [])].filter(
          (el) => el.classList.contains('anim-card')
        );
        const idx = siblings.indexOf(entry.target as Element);
        (entry.target as HTMLElement).style.transitionDelay = `${idx * 0.13}s`;
        entry.target.classList.add('visible');
        io.unobserve(entry.target);
      });
    },
    { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
  );

  cards.forEach((c) => io.observe(c));
</script>
