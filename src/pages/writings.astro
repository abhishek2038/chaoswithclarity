---
import Layout from '../layouts/Layout.astro';
import { sections, essays } from '../data/poems';
---
<Layout
  title="Poems & Essays on Ego, Awareness, and Being Alive — Chaos With Clarity"
  description="Read 40 poems and essays by Abby across five themes: being human, the inward turn, pain and transformation, freedom, and love. Free poems to read online."
  jsonLd={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "Writings — Chaos With Clarity",
    "description": "40 poems and essays by Abby on ego, awareness, meditation, pain, freedom, and love.",
    "url": "https://chaoswithclarity.com/writings",
    "isPartOf": { "@type": "WebSite", "name": "Chaos With Clarity", "url": "https://chaoswithclarity.com" }
  })}
>

  <!-- ══ PAGE HEADER ══════════════════════════════════════════ -->
  <section class="page-header">
    <div class="page-header-inner">
      <p class="overline" style="color:#e86850;">All Writings</p>
      <h1 class="page-h1" style="color:#f0f0f0;">Essays<br/>&amp; Poems</h1>
      <div class="header-rule" style="background:#d4a04a;"></div>
      <p class="page-sub" style="color:#c8b8a0;">
        Ideas that stay with you the next time you're scrolling at 2am,<br class="br-d"/>
        or wondering why you still feel restless even when everything looks fine on paper.
      </p>
    </div>
    <!-- decorative large word -->
    <p class="header-bg-word" aria-hidden="true">words</p>
  </section>

  <div class="writings-wrap">

    {sections.map((section) => (
      <section class="writings-section" id={section.id}>

        <div class="section-head">
          <p class="section-num" aria-hidden="true">{section.num}</p>
          <div class="section-label-row">
            <span class="section-dot" style={`background:${section.accent};`}></span>
            <h2 class="section-label-text" style={`color:${section.accent};`}>{section.label}</h2>
            <div class="section-line"></div>
          </div>
          {section.subtitle && <p class="section-subtitle">{section.subtitle}</p>}
        </div>

        {/* ── FREE POEMS FIRST ── */}
        <div class="poem-grid-3">
          {section.poems.filter(p => p.taster).map((poem) => (
            poem.previewOnly ? (
              <a
                href="/collection"
                class={`poem-card anim-card preview-only-card${poem.series ? ' trilogy-card' : ''}`}
                style={`--card-accent:${section.accent};`}
              >
                {poem.series && (
                  <p class="card-series">
                    {poem.series}{poem.seriesPart ? ` · ${poem.seriesPart}` : ''}
                  </p>
                )}
                <span class="preview-badge">Preview</span>
                <p class="card-date">{poem.date}</p>
                <h3 class="card-title">
                  {poem.title}
                  {poem.subtitle && (
                    <><br/><em class="card-subtitle">{poem.subtitle}</em></>
                  )}
                </h3>
                <div class="card-preview" style={`--prev-color:${section.accent};`}>
                  {poem.preview.map((line) => <p>{line}</p>)}
                </div>
                <span class="card-cta" style={`--cta:${section.accent};`}>
                  Read in the collection <i class="ph ph-arrow-right cta-arrow"></i>
                </span>
              </a>
            ) : (
              <article
                class={`poem-card anim-card${poem.series ? ' trilogy-card' : ''}`}
                style={`--card-accent:${section.accent};`}
                data-poem-card
                data-title={poem.subtitle ? `${poem.title} ${poem.subtitle}` : poem.title}
                data-date={poem.date}
                data-poem={poem.text}
                data-reflection={poem.reflection ?? ''}
              >
                {poem.series && (
                  <p class="card-series">
                    {poem.series}{poem.seriesPart ? ` · ${poem.seriesPart}` : ''}
                  </p>
                )}
                <span class="free-poem-badge">Free to read</span>
                <p class="card-date">{poem.date}</p>
                <h3 class="card-title">
                  {poem.title}
                  {poem.subtitle && (
                    <><br/><em class="card-subtitle">{poem.subtitle}</em></>
                  )}
                </h3>
                <div class="card-preview" style={`--prev-color:${section.accent};`}>
                  {poem.preview.map((line) => <p>{line}</p>)}
                </div>
                <span class="card-cta" style={`--cta:${section.accent};`}>
                  Read full poem <i class="ph ph-arrow-right cta-arrow"></i>
                </span>
              </article>
            )
          ))}
        </div>

        {/* ── REMAINING POEMS (locked) + link to collection ── */}
        {section.poems.filter(p => !p.taster).length > 0 && (
          <div class="more-poems-row anim-card">
            <p class="more-poems-count">+ {section.poems.filter(p => !p.taster).length} more poems in this section</p>
            <div class="more-poems-titles">
              {section.poems.filter(p => !p.taster).map((poem) => (
                <span class="more-poem-name">{poem.title}</span>
              ))}
            </div>
            <a href="/collection" class="more-poems-link" style={`--cta:${section.accent};`}>
              Get the full collection →
            </a>
          </div>
        )}

      </section>
    ))}

    <!-- ══ ESSAYS ══════════════════════════════════════════════ -->
    {essays.length > 0 && (
      <section class="writings-section" id="essays">

        <div class="section-head">
          <p class="section-num" aria-hidden="true" style="color:rgba(90,40,72,0.15);">VI</p>
          <div class="section-label-row" style="border-bottom-color:rgba(255,255,255,0.1);">
            <span class="section-dot" style="background:#e8c170;"></span>
            <h2 class="section-label-text" style="color:#e8c170;">Essays</h2>
            <div class="section-line"></div>
          </div>
          <p class="section-subtitle" style="color:#c8b8a0;">Longer reflections on consciousness, technology, and the examined life.</p>
        </div>

        <div class="essay-grid">
          {essays.map((essay) => (
            <div class="essay-card anim-card">
              <p class="essay-tag">Essay</p>
              <h3 class="essay-title">{essay.title}</h3>
              <p class="essay-desc">{essay.description}</p>
              {essay.snippet && <p class="essay-snippet">{essay.snippet}</p>}
            </div>
          ))}
        </div>

      </section>
    )}

    <!-- ══ WORK WITH ABBY ═════════════════════════════════════════ -->
    <section class="writings-section work-with-abby" id="work-with-abby">
      <div class="section-head">
        <p class="section-num" aria-hidden="true">VII</p>
        <div class="section-label-row">
          <span class="section-dot" style="background:var(--coral);"></span>
          <h2 class="section-label-text" style="color:var(--coral);">Work with Abby</h2>
          <div class="section-line"></div>
        </div>
        <p class="section-subtitle">One-on-one guidance for those navigating inner work, creative expression, or simply trying to live more honestly.</p>
      </div>

      <div class="work-abby-content">
        <div class="work-abby-intro">
          <p>Sometimes you don't need another book or course — you need a conversation with someone who has sat with the same questions.</p>
          <p>I offer personal, one-on-one sessions for anyone working through themes that show up in my writing: ego, awareness, identity, creative blocks, or just the quiet restlessness of wanting more from life.</p>
          <p>No frameworks. No jargon. Just honest conversation and practical clarity.</p>
          <ul class="work-abby-list">
            <li>Inner work &amp; self-awareness</li>
            <li>Creative expression &amp; writing</li>
            <li>Navigating transitions &amp; uncertainty</li>
            <li>Building a mindful, intentional life</li>
          </ul>
        </div>

        <form class="enquiry-form" action="https://formsubmit.co/abby@chaoswithclarity.com" method="POST">
          <input type="hidden" name="_subject" value="New enquiry from chaoswithclarity.com" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="https://chaoswithclarity.com/writings#work-with-abby" />
          <h3 class="form-title">Reach out</h3>
          <p class="form-subtitle">Tell me a little about yourself and what you're looking for. I'll get back to you personally.</p>
          <div class="form-field">
            <label for="enquiry-name">Name</label>
            <input type="text" id="enquiry-name" name="name" required placeholder="Your name" />
          </div>
          <div class="form-field">
            <label for="enquiry-email">Email</label>
            <input type="email" id="enquiry-email" name="email" required placeholder="you@example.com" />
          </div>
          <div class="form-field">
            <label for="enquiry-message">What's on your mind?</label>
            <textarea id="enquiry-message" name="message" rows="5" required placeholder="What are you working through? What kind of guidance are you looking for?"></textarea>
          </div>
          <button type="submit" class="form-submit">Send Enquiry</button>
        </form>
      </div>
    </section>

    <!-- ══ JOIN CTA ═══════════════════════════════════════════════ -->
    <div class="writings-cta anim-card">
      <p class="writings-cta-quote">
        These pieces arrive in your inbox.<br/>
        <em>Occasional. Honest. Worth it.</em>
      </p>
      <a href="/join" class="cta-btn">Get the Letters &rarr;</a>
    </div>

  </div>
</Layout>

<style>
  /* ══ PAGE HEADER ══════════════════════════════════════════════ */
  .page-header {
    padding: 6rem 3rem 4rem;
    background: #1a3a2a;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .page-header-inner {
    max-width: 72rem;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .overline {
    font-size: 0.66rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .page-h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(3.5rem, 9vw, 8rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin-bottom: 2rem;
  }
  .header-rule {
    width: 3rem;
    height: 3px;
    background: var(--coral);
    margin-bottom: 1.75rem;
  }
  .page-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.95;
    font-weight: 300;
    max-width: 42rem;
  }
  /* large decorative word behind header */
  .header-bg-word {
    position: absolute;
    bottom: 0;
    right: 0;
    font-family: 'Fraunces', serif;
    font-size: clamp(6rem, 18vw, 16rem);
    font-weight: 800;
    color: var(--border);
    opacity: 0.35;
    letter-spacing: -0.05em;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 1;
  }
  .br-d { display: inline; }

  /* ══ WRAPPER ══════════════════════════════════════════════════ */
  .writings-wrap {
    max-width: 100%;
    margin: 0 auto;
    padding: 0;
  }
  .writings-section {
    margin-bottom: 0;
    padding: 4rem 3rem;
  }
  .writings-section > * {
    max-width: 72rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* Per-section backgrounds */
  #being-human                   { background: #f5ece8; }
  #the-inward-turn               { background: #faf6ef; }
  #pain-and-transformation       { background: #f0e8dc; }
  #freedom-and-becoming          { background: #eaf0e8; }
  #love-nature-and-the-world     { background: #f5ece8; }
  #essays                        { background: #1a3a2a; }
  .work-with-abby                { background: #f0e8dc; }

  /* Section numbers — subtle burgundy */
  .writings-section .section-num { color: rgba(107,26,42,0.12); }

  /* Consistent burgundy left border on all cards */
  .poem-card       { border-left: 3px solid #6b1a2a; }
  #essays .essay-card { border-left: 3px solid #d4a04a; }

  /* Section divider line */
  .section-label-row { border-bottom-color: var(--border); }

  /* ══ SECTION HEADERS ══════════════════════════════════════════ */
  .section-head { margin-bottom: 3rem; }

  .section-num {
    font-family: 'Fraunces', serif;
    font-size: clamp(4rem, 9vw, 6.5rem);
    font-weight: 800;
    color: var(--border);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: -0.6rem;
    padding-left: 0.1rem;
  }
  .section-label-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .section-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .section-label-text {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 0;
  }
  .section-subtitle {
    font-size: 0.85rem;
    color: var(--text-faint);
    margin-top: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.01em;
    font-style: italic;
  }

  /* ══ POEM CARDS ═══════════════════════════════════════════════ */
  .poem-card {
    background: #ffffff;
    padding: 2.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-top: none;
    border-radius: 8px;
    box-shadow:
      0 2px 16px rgba(26,58,42,0.1),
      0 1px 4px rgba(26,58,42,0.05);
    cursor: pointer;
    transition:
      transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .poem-card:hover {
    transform: translateY(-9px);
    box-shadow:
      0 22px 60px rgba(42,36,24,0.08),
      0 6px 18px rgba(42,36,24,0.05);
  }

  .card-date {
    font-size: 0.63rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }
  .card-title {
    font-family: 'Fraunces', serif;
    font-size: 1.55rem;
    color: var(--text);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .card-subtitle {
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    color: var(--text-muted);
  }

  /* Preview with decorative quote mark */
  .card-preview {
    font-family: 'Fraunces', serif;
    font-style: italic;
    color: var(--text-muted);
    font-size: 0.97rem;
    line-height: 2.1;
    flex: 1;
    border-left: 3px solid var(--prev-color, var(--coral));
    padding-left: 1.3rem;
    position: relative;
  }
  .card-preview::before {
    content: '\201C';
    font-family: 'Fraunces', serif;
    font-size: 4rem;
    line-height: 0.6;
    font-style: normal;
    color: var(--border);
    display: block;
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .card-cta {
    font-size: 0.63rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cta, var(--coral));
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }
  .cta-arrow {
    transition: transform 0.25s ease;
  }
  .poem-card:hover .cta-arrow {
    transform: translateX(5px);
  }

  /* ══ PREVIEW-ONLY CARD ════════════════════════════════════════ */
  .preview-only-card {
    text-decoration: none;
    color: inherit;
  }
  .preview-badge {
    font-size: 0.56rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: #5a2848;
    background: #f0e0ec;
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    align-self: flex-start;
    margin-bottom: -0.5rem;
  }

  /* ══ FREE BADGE ══════════════════════════════════════════════ */
  .free-poem-badge {
    font-size: 0.56rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 700;
    color: #6b1a2a;
    background: #f0ddd8;
    padding: 0.25rem 0.65rem;
    border-radius: 3px;
    align-self: flex-start;
    margin-bottom: -0.5rem;
  }

  /* ══ MORE POEMS ROW ════════════════════════════════════════ */
  .more-poems-row {
    margin-top: 2rem;
    background: #ffffff;
    border-radius: 8px;
    padding: 2rem 2.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    box-shadow: 0 2px 12px rgba(26,58,42,0.08);
    border-left: 3px solid #6b1a2a;
  }
  .more-poems-count {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    white-space: nowrap;
  }
  .more-poems-titles {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    flex: 1;
  }
  .more-poem-name {
    font-size: 0.72rem;
    color: var(--text-faint);
    border: 1px solid var(--border);
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    font-style: italic;
  }
  .more-poems-link {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cta, var(--coral));
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .more-poems-link:hover { opacity: 0.75; }

  /* ══ ESSAY CARDS ══════════════════════════════════════════════ */
  .essay-card {
    background: rgba(255,255,255,0.08);
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    border-radius: 8px;
    box-shadow: none;
    transition:
      border-color 0.3s ease,
      box-shadow 0.35s ease,
      transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94);
    text-decoration: none;
    color: inherit;
  }
  .essay-card:hover {
    border-left-color: var(--text-faint);
    transform: translateY(-6px);
    box-shadow: 0 14px 40px rgba(42,36,24,0.06);
  }
  .essay-tag {
    font-size: 0.63rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #e86850;
    font-weight: 600;
  }
  .essay-title {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    color: #f0f0f0;
    font-weight: 700;
    line-height: 1.25;
  }
  .essay-desc {
    color: #c8b8a0;
    font-size: 0.9rem;
    line-height: 1.9;
  }
  .essay-snippet {
    color: #c8b8a0;
    font-size: 0.82rem;
    line-height: 1.85;
    font-style: italic;
    opacity: 0.75;
    margin-top: 0.25rem;
    flex: 1;
  }

  /* ══ TRILOGY ══════════════════════════════════════════════════ */
  .card-series {
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--coral);
    font-weight: 700;
    opacity: 0.75;
    margin-bottom: -0.5rem;
  }
  .trilogy-card {
    border-top-width: 3px;
    border-top-style: dashed;
  }

  /* ══ SCROLL ANIMATION ═════════════════════════════════════════ */
  .anim-card {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.75s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      box-shadow 0.4s ease;
  }
  .anim-card.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .poem-card.anim-card.visible:hover  { transform: translateY(-9px); }
  .essay-card.anim-card.visible:hover { transform: translateY(-6px); }

  /* ══ WORK WITH ABBY ═══════════════════════════════════════════ */
  .work-abby-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  .work-abby-intro p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.9;
    margin-bottom: 1rem;
  }
  .work-abby-list {
    list-style: none;
    padding: 0;
    margin-top: 1.25rem;
  }
  .work-abby-list li {
    font-size: 0.88rem;
    color: var(--text);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    padding-left: 1.25rem;
    position: relative;
  }
  .work-abby-list li::before {
    content: '◆';
    position: absolute;
    left: 0;
    color: var(--coral);
    font-size: 0.5rem;
    top: 0.7rem;
  }
  .enquiry-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-title {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0;
  }
  .form-subtitle {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .form-field label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 600;
  }
  .form-field input,
  .form-field textarea {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.9rem;
    padding: 0.75rem 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    outline: none;
    transition: border-color 0.2s;
  }
  .form-field input:focus,
  .form-field textarea:focus {
    border-color: var(--coral);
  }
