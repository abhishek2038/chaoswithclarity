---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Chaos With Clarity — Poetry & Essays by Abby"
  description="Short, honest ideas about ego, experience, and being fully alive. Poetry, essays, and inner work for people who think too much and feel even more."
  jsonLd={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Chaos With Clarity",
    "url": "https://chaoswithclarity.com",
    "description": "Poetry, essays, and inner work by Abby — short honest ideas about ego, experience, and being fully alive.",
    "author": {
      "@type": "Person",
      "name": "Abby",
      "url": "https://chaoswithclarity.com/about",
      "sameAs": ["https://instagram.com/iamabbyjain", "https://youtube.com/@iamabbyjain"]
    }
  })}
>

  <!-- ══ HERO ══════════════════════════════════════════════ -->
  <section style="min-height:100svh;background:#1a3a2a;display:flex;flex-direction:column;justify-content:center;padding:5rem 3rem 4rem;position:relative;overflow:hidden;">
    <!-- background video — loops first 5 sec via JS below -->
    <video id="hero-vid" autoplay muted loop playsinline preload="metadata" aria-hidden="true" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;opacity:0.3;">
      <source src="/images/abby-video.mp4" type="video/mp4" />
    </video>
    <!-- dark overlay — cinematic depth -->
    <div style="position:absolute;inset:0;background:#1a3a2a;opacity:0.5;z-index:1;pointer-events:none;"></div>

    <div style="max-width:72rem;margin:0 auto;width:100%;position:relative;z-index:2;">
      <p style="font-size:0.68rem;letter-spacing:0.3em;text-transform:uppercase;color:#e86850;margin-bottom:2rem;font-weight:600;">Essays · Poetry · Inner Work</p>

      <h1 style="font-family:'Fraunces',serif;letter-spacing:-0.03em;line-height:0.9;margin-bottom:2.5rem;">
        <span style="display:block;font-size:clamp(4rem,10vw,9rem);font-weight:800;color:#f0f0f0;">Chaos</span>
        <span style="display:block;font-size:clamp(1.6rem,3.8vw,3.4rem);font-weight:400;font-style:italic;color:#d4a04a;padding-left:clamp(1rem,3vw,3rem);line-height:1.5;">With</span>
        <span style="display:block;font-size:clamp(4rem,10vw,9rem);font-weight:800;color:#f0f0f0;">Clarity</span>
      </h1>

      <p style="color:#c8b8a0;font-size:clamp(0.95rem,1.8vw,1.1rem);line-height:2.1;max-width:36rem;margin-bottom:1.5rem;font-weight:300;border-left:2px solid #d4a04a;padding-left:1.25rem;">
        Short, honest ideas about ego, experience, and being fully alive.<br/>
        <em style="color:#e86850;font-style:italic;">For people who think too much and feel even more.</em>
      </p>

      <p style="color:#c8b8a0;font-size:0.95rem;max-width:36rem;line-height:1.9;margin-bottom:3rem;font-weight:300;">
        I'm Abby, a writer and creator who turns the mess of everyday life into lines that make you pause, breathe, and see differently. This is the calm corner of the internet where we slow down, question everything, and leave a little lighter than we arrived.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:1rem;">
        <a href="/writings" style="display:inline-block;background:#e86850;color:#ffffff;font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:600;border-radius:4px;transition:background 0.2s;" onmouseover="this.style.background='#d05840'" onmouseout="this.style.background='#e86850'">Read the Writing</a>
        <a href="https://youtube.com/@iamabbyjain" target="_blank" rel="noopener" style="display:inline-block;border:1px solid rgba(255,255,255,0.2);color:#c8b8a0;font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:500;border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='#d4a04a';this.style.color='#f0f0f0'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#c8b8a0'">Watch the Reels</a>
        <a href="/join" style="display:inline-block;border:1px solid rgba(255,255,255,0.2);color:#c8b8a0;font-size:0.76rem;letter-spacing:0.15em;text-transform:uppercase;padding:1rem 2.25rem;text-decoration:none;font-weight:500;border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='#d4a04a';this.style.color='#f0f0f0'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)';this.style.color='#c8b8a0'">Get the Letters</a>
      </div>
    </div>
  </section>

  <!-- ══ THIS SPACE IS FOR YOU ══════════════════════════════ -->
  <section style="padding:4rem 3rem;background:#f5ece8;">
    <div style="max-width:72rem;margin:0 auto;display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start;" class="for-you-grid">
      <div style="position:sticky;top:7rem;">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#6b1a2a;margin-bottom:1rem;font-weight:600;">This space is for you if</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:700;color:var(--text);line-height:1.05;">You feel it<br/><em style="font-weight:400;color:#6b1a2a;">before you<br/>name it.</em></h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:0;">
        {[
          "You're tired of empty motivation and want depth without the jargon.",
          "You overthink, feel a lot, and secretly like that about yourself.",
          "You're curious about mindfulness, but allergic to perfectionism and spiritual performance.",
          "You want to own fewer things, carry less ego, and experience more life."
        ].map((line, i) => (
          <div style={`padding:2rem 0;border-bottom:1px solid #ddd0c0;${i===0?'border-top:1px solid #ddd0c0;':''}`}>
            <p style="font-size:1rem;color:var(--text);font-weight:500;line-height:1.65;">{line}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ FEATURED POEM ══════════════════════════════════════ -->
  <section style="padding:4rem 3rem;background:#faf6ef;">
    <div style="max-width:72rem;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid #ddd0c0;border-radius:10px;overflow:hidden;box-shadow:0 4px 24px rgba(26,58,42,0.08);" class="poem-home-grid">

      <article style="padding:3.5rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:1.25rem;"
               data-poem-card
               data-title="Unstruck Silence (Anhat Nad)"
               data-date="March 2026"
               data-poem="It starts but never ends,
It is just life, nothing to amend.

Silence is louder than noise,
Once you hear it, it abides.

Anhat Nad, it is said,
The uncreated sound that spreads.
Not from anywhere near or far,
Always present, revealing scars.

Contradiction is life's way of being,
Fighting it is simply fleeing.

Give your heart a pause,
Breathe in and listen to the cosmos.
It enters you and penetrates deep,
Making every restless cell sleep.

I know it sounds absurd,
That is why words feel blurred.

It starts but never ends,
It is just life, nothing to amend.

Empty the weight you carry in your heart,
Just be, and let silence be the start.

A start not of something new,
But something in you you always knew.

You are so small, yet vast the roles you play,
Trying to be more as life slips away.

To be ahead is just a muse,
Your breaths are counted, if you choose to view.

See what you truly hold,
Let go of wanting, and be bold.

Let silence become your home,
Be less, not more.

Be less, not more."
               data-reflection="">
        <p style="font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:#e86850;font-weight:600;">Featured Poem · March 2026</p>
        <h3 style="font-family:'Fraunces',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:700;color:var(--text);line-height:1.15;">Unstruck Silence<br/><em style="font-weight:400;font-size:0.8em;color:var(--text-muted);">(Anhat Nad)</em></h3>
        <div style="font-family:'Fraunces',serif;font-style:italic;color:var(--text-muted);font-size:1.05rem;line-height:2.2;border-left:3px solid #6b1a2a;padding-left:1.5rem;flex:1;">
          <p>It starts but never ends,</p>
          <p>It is just life, nothing to amend.</p>
          <p>Silence is louder than noise,</p>
          <p>Once you hear it, it abides.</p>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <span style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:#e86850;font-weight:600;">Click to read</span>
          <i class="ph ph-arrow-right" style="color:#e86850;font-size:0.9rem;"></i>
        </div>
      </article>

      <div style="background:#1a3a2a;padding:3.5rem;display:flex;flex-direction:column;justify-content:space-between;gap:2rem;">
        <div>
          <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#d4a04a;margin-bottom:1.5rem;font-weight:600;">About this space</p>
          <p style="font-family:'Fraunces',serif;font-size:1.4rem;font-weight:500;color:#f0f0f0;line-height:1.5;margin-bottom:1.25rem;">
            "Spreadsheets couldn't answer the chest ache. So I write."
          </p>
          <p style="font-size:0.92rem;color:#c8b8a0;line-height:1.9;">Nine years of finance, from EY audit rooms to sitting across from founders who had everything and felt nothing, taught me one thing: clarity without depth is just noise with good formatting.</p>
        </div>
        <div>
          <a href="/about" style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:#c8b8a0;text-decoration:none;border:1px solid rgba(255,255,255,0.15);padding:0.75rem 1.75rem;display:inline-block;font-weight:500;border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='#d4a04a';this.style.color='#f0f0f0'" onmouseout="this.style.borderColor='rgba(255,255,255,0.15)';this.style.color='#c8b8a0'">About Abby →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ EXPLORE THE THEMES ══════════════════════════════════ -->
  <section style="padding:5rem 3rem;background:#f0e8dc;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3.5rem;">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#6b1a2a;margin-bottom:1rem;font-weight:600;">Five Themes</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3rem);font-weight:700;color:var(--text);line-height:1.1;">Explore the Writing</h2>
      </div>
      <div class="themes-grid">
        <a href="/writings#being-human" class="theme-card" style="border-left:4px solid #e86850;">
          <span class="theme-num">01</span>
          <h3 class="theme-title">Being Human</h3>
          <p class="theme-desc">On mortality, ego, identity, and what it means to be alive.</p>
        </a>
        <a href="/writings#the-inward-turn" class="theme-card" style="border-left:4px solid #1a3a2a;">
          <span class="theme-num">02</span>
          <h3 class="theme-title">The Inward Turn</h3>
          <p class="theme-desc">On meditation, awareness, the observer, and quiet reflections.</p>
        </a>
        <a href="/writings#pain-and-transformation" class="theme-card" style="border-left:4px solid #c45050;">
          <span class="theme-num">03</span>
          <h3 class="theme-title">Pain & Transformation</h3>
          <p class="theme-desc">On suffering, grief, darkness, and the slow work of healing.</p>
        </a>
        <a href="/writings#freedom-and-becoming" class="theme-card" style="border-left:4px solid #2a5a3a;">
          <span class="theme-num">04</span>
          <h3 class="theme-title">Freedom & Becoming</h3>
          <p class="theme-desc">On letting go, liberation, searching for self, and finding purpose.</p>
        </a>
        <a href="/writings#love-nature-and-the-world" class="theme-card" style="border-left:4px solid #d4a04a;">
          <span class="theme-num">05</span>
          <h3 class="theme-title">Love, Nature & The World</h3>
          <p class="theme-desc">On human bonds, the living world, and being fully present.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ══ PULL QUOTE ══════════════════════════════════════════ -->
  <section style="background:#5a2848;padding:4rem 3rem;text-align:center;">
    <div style="max-width:42rem;margin:0 auto;">
      <div style="width:2rem;height:2px;background:#e8c170;margin:0 auto 1.75rem;"></div>
      <blockquote style="font-family:'Fraunces',serif;font-style:italic;font-size:clamp(1.15rem,2.5vw,1.6rem);color:#f0f0f0;line-height:1.9;margin-bottom:1rem;">
        "Every poem begins in chaos and ends, not in answers, but in something clearer."
      </blockquote>
      <p style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:#e8c170;font-weight:600;">— Abby</p>
    </div>
  </section>

  <!-- ══ THE COLLECTION ══════════════════════════════════════ -->
  <section style="padding:5rem 3rem;background:#eaf0e8;">
    <div style="max-width:72rem;margin:0 auto;" class="collection-home-grid">
      <div class="collection-text">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#1a5a5a;margin-bottom:1rem;font-weight:600;">Digital Downloads</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,4vw,3rem);font-weight:700;color:var(--text);line-height:1.1;margin-bottom:1.25rem;">Take the poems<br/><em style="font-weight:400;color:var(--text-muted);">with you.</em></h2>
        <p style="color:var(--text-muted);font-size:0.95rem;line-height:2;margin-bottom:1.5rem;">Forty poems across five themes. Two free chapbooks. A set of printable poem cards. Written between 2024 and 2026 on mortality, ego, meditation, pain, freedom, and love.</p>
        <div class="collection-stats">
          <div class="stat-item">
            <span class="stat-num">40</span>
            <span class="stat-label">poems</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">2</span>
            <span class="stat-label">free chapbooks</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-num">$9</span>
            <span class="stat-label">full collection</span>
          </div>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;margin-top:2rem;">
          <a href="/collection" style="display:inline-block;background:#6b1a2a;color:#f0f0f0;font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.9rem 1.75rem;text-decoration:none;font-weight:600;border-radius:4px;transition:background 0.2s;" onmouseover="this.style.background='#8a2a3a'" onmouseout="this.style.background='#6b1a2a'">Browse the Collection</a>
          <a href="https://chaoswithclarity.gumroad.com/l/poems" target="_blank" rel="noopener" style="display:inline-block;border:1px solid var(--border);color:var(--text-muted);font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;padding:0.9rem 1.75rem;text-decoration:none;font-weight:500;border-radius:4px;transition:all 0.2s;" onmouseover="this.style.borderColor='#6b1a2a';this.style.color='var(--text)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">Get the PDF →</a>
        </div>
      </div>
      <div class="collection-preview">
        <div class="mini-book">
          <p class="mini-book-label">The Complete Work</p>
          <p class="mini-book-title">CHAOS<br/>WITH<br/>CLARITY</p>
          <div style="width:2rem;height:2px;background:#e86850;margin:0.5rem 0;"></div>
          <p class="mini-book-sub">A Collection of Poems</p>
          <p class="mini-book-author">Abby</p>
          <p class="mini-book-count">40 Poems · 2024–2026</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ ESSAYS PREVIEW ══════════════════════════════════════ -->
  <section style="padding:5rem 3rem;background:#faf6ef;">
    <div style="max-width:72rem;margin:0 auto;">
      <div style="text-align:center;margin-bottom:3rem;">
        <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#5a2848;margin-bottom:1rem;font-weight:600;">Coming Soon</p>
        <h2 style="font-family:'Fraunces',serif;font-size:clamp(1.8rem,3.5vw,2.5rem);font-weight:700;color:var(--text);line-height:1.1;">Essays on the examined life</h2>
      </div>
      <div class="essays-home-grid">
        <div class="essay-preview-card">
          <p style="font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#e86850;font-weight:600;margin-bottom:0.75rem;">Essay</p>
          <h3 style="font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700;color:var(--text);margin-bottom:0.6rem;line-height:1.3;">Who Owns You?</h3>
          <p style="color:var(--text-muted);font-size:0.88rem;line-height:1.9;">On attention, algorithms, and reclaiming the self. You open the phone for one thing and thirty minutes later you are somewhere else entirely.</p>
        </div>
        <div class="essay-preview-card">
          <p style="font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#e86850;font-weight:600;margin-bottom:0.75rem;">Essay</p>
          <h3 style="font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700;color:var(--text);margin-bottom:0.6rem;line-height:1.3;">We Were Never Meant for Intelligence</h3>
          <p style="color:var(--text-muted);font-size:0.88rem;line-height:1.9;">Why consciousness precedes cognition — and what we lost when we forgot. We built machines that think faster than us and called it progress.</p>
        </div>
        <div class="essay-preview-card">
          <p style="font-size:0.63rem;letter-spacing:0.22em;text-transform:uppercase;color:#e86850;font-weight:600;margin-bottom:0.75rem;">Essay</p>
          <h3 style="font-family:'Fraunces',serif;font-size:1.2rem;font-weight:700;color:var(--text);margin-bottom:0.6rem;line-height:1.3;">Choosing Reality Over Symbols</h3>
          <p style="color:var(--text-muted);font-size:0.88rem;line-height:1.9;">Money, status, degrees — and the life that happens while you chase them. The degree hangs on the wall. And still, something is missing.</p>
        </div>
      </div>
      <div style="text-align:center;margin-top:2.5rem;">
        <a href="/writings#essays" style="font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:#5a2848;text-decoration:none;font-weight:600;transition:opacity 0.2s;" onmouseover="this.style.opacity='0.7'" onmouseout="this.style.opacity='1'">View all writings →</a>
      </div>
    </div>
  </section>

  <!-- ══ NEWSLETTER CTA ══════════════════════════════════════ -->
  <section style="background:#1a3a2a;padding:5rem 3rem;">
    <div style="max-width:50rem;margin:0 auto;text-align:center;">
      <p style="font-size:0.68rem;letter-spacing:0.28em;text-transform:uppercase;color:#e86850;margin-bottom:1.5rem;font-weight:600;">The Letters</p>
      <h2 style="font-family:'Fraunces',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:700;color:#f0f0f0;line-height:1.05;margin-bottom:1.5rem;">
        Honest notes from<br/><em style="font-weight:400;color:#d4a04a;">the middle of it all.</em>
      </h2>
      <p style="color:#c8b8a0;font-size:0.95rem;line-height:1.9;max-width:36rem;margin:0 auto 2.5rem;font-weight:300;">
        Thoughts I don't share on Instagram or YouTube. Drafts, behind-the-scenes process, questions I'm still figuring out. No spam. No "daily grind" tips. Just honest notes.
      </p>
      <a href="/join" style="display:inline-block;background:#e86850;color:#ffffff;font-size:0.76rem;letter-spacing:0.18em;text-transform:uppercase;padding:1.1rem 2.5rem;text-decoration:none;font-weight:700;border-radius:4px;transition:background 0.2s;" onmouseover="this.style.background='#d05840'" onmouseout="this.style.background='#e86850'">Get the Letters</a>
    </div>
  </section>

</Layout>

<style>
  /* ── THEMES GRID ────────────────────────────── */
  .themes-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }
  .theme-card {
    background: #ffffff;
    padding: 2rem 1.75rem;
    border-radius: 8px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    box-shadow: 0 2px 12px rgba(26,58,42,0.08);
    transition: transform 0.3s, box-shadow 0.3s;
  }
  .theme-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(26,58,42,0.12);
  }
  .theme-num {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 800;
    color: var(--border);
    line-height: 1;
  }
  .theme-title {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
  }
  .theme-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* ── COLLECTION SECTION ─────────────────────── */
  .collection-home-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .collection-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .stat-num {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 800;
    color: #1a5a5a;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
    font-weight: 500;
  }
  .stat-divider {
    width: 1px;
    height: 2.25rem;
    background: var(--border);
  }
  .mini-book {
    background: #ffffff;
    padding: 2.5rem 2rem;
    border-left: 5px solid #e86850;
    display: flex;
    flex-direction: column;
