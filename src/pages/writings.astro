          </article>
        ))}
      </div>
    </section>

    <!-- JOIN CTA -->
    <div class="border-t border-cwc-border pt-12 text-center reveal">
      <p class="font-serif italic text-cwc-muted mb-6">These poems arrive in your inbox every week.</p>
      <a href="/join"
         class="text-xs tracking-widest uppercase bg-cwc-accent text-cwc-bg px-8 py-3 hover:bg-cwc-accent-dark transition-colors">
        Join the List →
      </a>
    </div>

  </div>
</Layout>
